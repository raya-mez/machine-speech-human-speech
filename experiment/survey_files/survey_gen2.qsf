            "SecondaryAttribute": "Below you can find each original sentence alongside your edited version. Explain each change you...",
            "TertiaryAttribute": null,
            "Payload": {
                "QuestionText": "Below you can find each original sentence alongside your edited version. \n<b>Explain</b> each change you made in the box below each pair.",
                "DefaultChoices": false,
                "DataExportTag": "explain_c20",
                "QuestionID": "QID1219691513",
                "QuestionType": "TE",
                "Selector": "ML",
                "DataVisibility": {
                    "Private": false,
                    "Hidden": false
                },
                "Configuration": {
                    "QuestionDescriptionOption": "UseText"
                },
                "QuestionDescription": "Below you can find each original sentence alongside your edited version. Explain each change you...",
                "Validation": {
                    "Settings": {
                        "ForceResponse": "OFF",
                        "ForceResponseType": "ON",
                        "Type": "None",
                        "MinChars": "1"
                    }
                },
                "GradingData": [],
                "Language": [],
                "NextChoiceId": 4,
                "NextAnswerId": 1,
                "SearchSource": {
                    "AllowFreeResponse": "false"
                },
                "QuestionJS": "// ----------\n// HELPER FUNCS\n// ----------\n\n// --- word-level diffs helper ---\nfunction wordDiff(orig, edited) {\n    // tokenize: split into words; punctuation treated as separate tokens\n    function tokenize(str) {\n        return str.match(/[a-zA-Z0-9']+|[^a-zA-Z0-9'\\s]/g) || []\n    }\n\n    var origWords = tokenize(orig)\n    var editedWords = tokenize(edited)\n    var result = document.createDocumentFragment() // build diffs display in a fragment to be inserted into the DOM at once\n    // fragment is iteratively built from <span> elements\n\n    var m = origWords.length,\n        n = editedWords.length\n    var dp = [] // dynamic programming table\n\n    // initialize dp table\n    for (var i = 0; i <= m; i++) {\n        dp[i] = []\n        for (var j = 0; j <= n; j++) dp[i][j] = 0\n    }\n\n    // compute longest common subsequence length\n    // iterate over original (i) and edited (j) sentences, word by word\n    for (var i = 1; i <= m; i++)\n        for (var j = 1; j <= n; j++)\n            // fill dp table\n            dp[i][j] =\n                // note: dp[1][1] corresp to origWords[0] vs editedWords[0] => hence -1 offset\n                origWords[i - 1] === editedWords[j - 1] // test match\n                    ? dp[i - 1][j - 1] + 1 // if match => extend LCS count by 1\n                    : Math.max(dp[i - 1][j], dp[i][j - 1]) // if no match => take max achievable LCS by removing from orig or edited\n\n    // backtrack to find and store edit operations (keep/add/remove)\n    var ops = [],\n        // start from end of table\n        i = m,\n        j = n\n    while (i > 0 || j > 0) {\n        // \"keep\" if i and j words at current position match\n        if (i > 0 && j > 0 && origWords[i - 1] === editedWords[j - 1]) {\n            // prepend <span> for kept word\n            ops.unshift({ type: \"keep\", word: editedWords[j - 1] })\n            i--\n            j--\n            // \"add\" if no match and j word has no i counterpart (move left)\n            // prefer add over remove if tie in LCS length (arbitrary choice)\n        } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {\n            ops.unshift({ type: \"add\", word: editedWords[j - 1] })\n            j--\n        } else {\n            // \"remove\" if no match and i word has no j counterpart (move up)\n            ops.unshift({ type: \"remove\", word: origWords[i - 1] })\n            i--\n        }\n    }\n\n    // apply stored edit operations to build final diff display\n    ops.forEach(function (op, k) {\n        // create a <span> for each word (word-level operation) and style according to operation type\n        var span = document.createElement(\"span\")\n        // test if word is punctuation\n        var isPunct = /^[^a-zA-Z0-9']$/.test(op.word)\n        // remove whitespace from start/end of punctuation tokens to avoid weird spacing in the diff display but keep spacing for regular words\n        span.textContent = (k > 0 && !isPunct ? \" \" : \"\") + op.word\n        // style <span> according to operation type\n        if (op.type === \"add\") {\n            span.className = \"diff-add\"\n        } else if (op.type === \"remove\") {\n            span.className = \"diff-remove\"\n        }\n        result.appendChild(span)\n    })\n\n    return result\n}\n\n// --- answer validation ---\nfunction isValidExplanation(text) {\n    var trimmed = text.trim()\n\n    // min 8 characters\n    if (trimmed.length < 8) return false\n\n    // min 2 words\n    var words = trimmed.split(/\\s+/).filter(function (w) {\n        return w.length > 0\n    })\n    if (words.length < 2) return false\n\n    // min 2 distinct words\n    var lower = words.map(function (w) {\n        return w.toLowerCase()\n    })\n    var unique = lower.filter(function (w, i) {\n        return lower.indexOf(w) === i\n    })\n    if (unique.length < 2) return false\n\n    // min 1 vowel\n    if (!/[aeiouAEIOU]/.test(trimmed)) return false\n\n    // less than half of all characters are digits\n    var digitCount = (trimmed.match(/[0-9]/g) || []).length\n    if (digitCount > trimmed.length / 2) return false\n\n    return true\n}\n\nfunction saveExplanations() {\n    var explanations = []\n    document.querySelectorAll(\".explanationBox\").forEach(function (box) {\n        explanations.push({\n            index: parseInt(box.dataset.index, 10),\n            explanation: box.value.trim(),\n        })\n    })\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditExplanationsJSON\",\n        // JSON.stringify(explanations),\n        btoa(unescape(encodeURIComponent(JSON.stringify(explanations)))),\n    )\n}\n\n// ----------\n// GLOBAL VARS\n// ----------\nvar qContainer\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    // get question container\n    qContainer = this.getQuestionContainer()\n\n    // get raw sentence pairs from embedded data\n    var rawSentencePairs = \"${e://Field/EditPairsJSON}\"\n\n    // decode and parse pairs from JSON\n    var pairs\n    var json = decodeURIComponent(escape(atob(rawSentencePairs)))\n    pairs = JSON.parse(json)\n\n    // --- display ---\n    // hide default Qualtrics text box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    // create main container as div\n    var container = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(container)\n\n    // render one block per sentence pair\n    pairs.forEach(function (pair, idx) {\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        // header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        // original sentence\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n        var origStrong = document.createElement(\"div\")\n        origStrong.className =\n            \"sentence_type-label sentence_type-label--original\"\n        origStrong.textContent = \"Original\"\n        origDiv.appendChild(origStrong)\n        origDiv.appendChild(document.createTextNode(pair.orig))\n        wrapper.appendChild(origDiv)\n\n        // submitted sentence\n        var editedDiv = document.createElement(\"div\")\n        // check edits were made => to determine display style + whether to attach explanation box\n        var isModified = pair.orig !== pair.edited\n        editedDiv.className =\n            \"sentence_block-edit\" +\n            (isModified ? \" sentence_block-edit--modified\" : \"\")\n        var editedStrong = document.createElement(\"div\")\n        editedStrong.className =\n            \"sentence_type-label \" +\n            (isModified\n                ? \"sentence_type-label--edit\"\n                : \"sentence_type-label--original\")\n        // label\n        editedStrong.textContent = isModified ? \"Your edit\" : \"Unchanged\"\n        editedDiv.appendChild(editedStrong)\n        editedDiv.appendChild(wordDiff(pair.orig, pair.edited))\n        wrapper.appendChild(editedDiv)\n\n        // explanation prompt + text box only if modified\n        if (isModified) {\n            var label = document.createElement(\"div\")\n            label.className = \"explanation-label\"\n            label.textContent = \"Why did you make this/these change(s)?\"\n            wrapper.appendChild(label)\n\n            var explanationBox = document.createElement(\"textarea\")\n            explanationBox.rows = 3\n            explanationBox.className = \"explanation-textarea explanationBox\"\n            explanationBox.dataset.index = idx\n            wrapper.appendChild(explanationBox)\n        }\n\n        container.appendChild(wrapper)\n    })\n\n    // --- require all & valid explanations ---\n    var nextBtn = document.getElementById(\"NextButton\")\n\n    if (nextBtn) {\n        // next-click listener\n        nextBtn.addEventListener(\n            \"click\",\n            function (e) {\n                var boxes = document.querySelectorAll(\".explanationBox\")\n                var allFilled = true\n                var firstInvalidBox = null // keep track of the first invalid box to jump back to if needed\n\n                boxes.forEach(function (box) {\n                    box.style.border = \"1px solid #ddd\"\n                    var errorMsg =\n                        box.parentNode.querySelector(\".explanationError\")\n                    if (errorMsg) errorMsg.remove()\n\n                    // check validity of explanation text\n                    if (!isValidExplanation(box.value)) {\n                        allFilled = false\n                        box.style.border = \"1px solid #e57373\"\n                        var error = document.createElement(\"div\")\n                        error.className = \"explanationError explanation-error\"\n                        error.textContent =\n                            \"Please explain why you made this change.\"\n                        box.parentNode.insertBefore(error, box.nextSibling)\n                        if (!firstInvalidBox) firstInvalidBox = box\n                    }\n                })\n\n                // if invalid or incomplete answers, scroll to first problematic box\n                if (!allFilled) {\n                    e.stopImmediatePropagation()\n                    e.preventDefault()\n                    firstInvalidBox.scrollIntoView({\n                        behavior: \"smooth\",\n                        block: \"center\",\n                    })\n                    firstInvalidBox.focus()\n                } else {\n                    // if all validly filled, save explanations\n                    saveExplanations()\n                }\n            },\n            true,\n        )\n    } else {\n        console.log(\"NextButton not found\")\n    }\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    // fallback save in case addOnPageSubmit fires without going through the click handler\n    // note: then explanations are not validated\n    saveExplanations()\n})",
                "QuestionText_Unsafe": "Below you can find each original sentence alongside your edited version. <b>Explain</b> each change you made in the box below each pair."
            }
        },
        {
            "SurveyID": "SV_cwM3MQomjAv0nJA",
            "Element": "SQ",
            "PrimaryAttribute": "QID1219691514",
            "SecondaryAttribute": "Imagine you find yourself in the following situation. As part of a group project, your team has t...",
            "TertiaryAttribute": null,
            "Payload": {
                "QuestionText": "Imagine you find yourself in the following situation.<br /><br />\n\nAs part of a group project, your team has to submit a 200-word news article and\nyour teammate, Brandon, is in charge of writing it. To do so, he used the newest\nLLM, designed to have a very human-like writing style.\n<br /><br />\n\nHowever, this puts your group at risk. Your professor actively tracks new\ndevelopments in LLMs and has already cautioned against their use in coursework.\nYou are worried he will suspect the article was produced with the help of an\nLLM, which would penalize the entire group.\n<br /><br />\n\n<strong>Your task</strong> is therefore to edit the text so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br /><br />\n\nTo get a better sense of the writing style of this new LLM, you first generate\ntwo sample articles using it. They are shown below.<br /><br />\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Example 1</div>\n        <div class=\"stimulus-title\">Why Wikipedia's cofounder wants to replace the online encyclopedia with the blockchain</div>\n        <div class=\"stimulus-body\">   <p>Jimmy Wales, who co-founded Wikipedia some 25 years ago, says the online encyclopaedia needs a radical overhaul and that blockchain technology could provide the change that is needed. At a technology conference this week, Wales stated that he believed Wikipedia\u2019s volunteer-driven model has struggled with issues including declining editor participation, opaque governance disputes and growing mistrust over content moderation.</p>\n           <p>Under his proposal he stated that articles and edits would be recorded on a public blockchain thereby effectively creating a transparent, tamper-resistant history of every contribution. He stated that members of the public could become contributors to the programme, earning digital tokens for verified edits, in the hope of attracting subject-matter experts. Mr Wales believed that so called 'smart' contracts might be helpful in creating a more harmonious editorial platform.</p>\n           <p>Wales hoped that his plans would make it harder for the site to be manipulated by ill meaning actors and that giving power to a broader cohort of people would reduce complaints about the current smaller administrator groups. Those critical of his ideas appear unconvinced that his blockchain systems can be scaled up to handle Wikipedia's popularity and warn that token incentives might encourage low-quality edits.</p>\n           <p>The Wikimedia Foundation stated that it was always interested in new ideas but that remaining non profit, whist embracing community governance is key. The future of Wikipedia would seem to be uncertain. Whether it can reinvent itself whilst remaining a Trusted brand only time will tell.</p></div>\n    </div>\n\n    <div class=\"card\">\n        <div class=\"card-label\">Example 2</div>\n        <div class=\"stimulus-title\">Inside the Beijing Dance Academy</div>\n        <div class=\"stimulus-body\">   <p>Inside the marble corridors of the Beijing Dance Academy, there's an echo of pointe shoes and the commands of established instructors. Founded in 1954, the prestigious institution has become the spot for China\u2019s most accomplished ballet and classical dancers, blending Russian-inspired technique with traditional Chinese aesthetics.</p>\n           <p>Inside, students as young as eleven train for hours each day, balancing academic studies with challenging rehearsals. Faculty members, many of whom are former principal dancers, emphasize discipline, precision, and emotional expression. \u201cTechnique is only the beginning,\u201d says Li Xinyue, a senior instructor at the institution. \u201cWe teach our students to tell stories that resonate beyond borders.\u201d</p>\n           <p>The academy\u2019s studios are lined with mirrors and barres, but also with calligraphy scrolls and framed production stills from historic ballets. Recent graduates have joined leading companies in Shanghai, London, and New York, reflecting the school\u2019s growing international reach.</p>\n           <p>Competition for a place at these companies is ruthless. Each year, thousands audition for a handful of places, driven by dreams of center stage. As China invests heavily in cultural diplomacy, the Beijing Dance Academy stands as both a training ground and symbol of artistic ambition and expression. Administrators say new scholarships aim to widen access for rural and lower-income applicants next year as they commit to sweeping reforms.</p></div>\n    </div>\n</div>\n\n<br />\nWith these examples in mind, you now turn to\n<strong>Brandon's text</strong> below. It will be shown again on the next page\nwith space to make your edits. <br /><br />\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Brandon's essay</div>\n        <div class=\"stimulus-title\">Newly Discovered Prehistoric Worm Creature 'Strange Beyond Measure'</div>\n        <div class=\"stimulus-body\">   <p>Scientists have discovered a prehistoric worm-like creature they describe as \u201cstrange beyond measure,\u201d showing an unusual branch of early animal evolution. The fossilized remains was found in 520\u2011million\u2011year\u2011old marine sediments in western China. It revealed a soft-bodied organism with a tubular form, ringed segments, and a circular mouth lined with sharp, backward-facing spines.</p>\n           <p>Measuring just a few inches long, the creature likely lived on the seafloor during the Cambrian Period. Researchers believe it used its spiny mouth to latch onto prey or organic debris, drawing food into a simple digestive tract. Despite its modest size, the worm\u2019s anatomy is unique.</p>\n           <p>\u201cIt\u2019s strange beyond measure,\u201d said lead paleontologist Dr. Li Wen. \u201cIts combination of features doesn\u2019t neatly fit into any known group, living or extinct.\u201d Advanced imaging techniques revealed preserved muscle fibers and traces of internal organs, offering rare insight into soft-bodied animals that seldom fossilize.</p>\n           <p>The discovery suggests that early marine ecosystems were more diverse  than previously understood. Scientists hope further study will clarify where this creature fits on the evolutionary tree and what it reveals.</p></div>\n    </div>\n</div>\n",
                "DefaultChoices": false,
                "DataExportTag": "instruct_c21",
                "QuestionID": "QID1219691514",
                "QuestionType": "DB",
                "Selector": "TB",
                "DataVisibility": {
                    "Private": false,
                    "Hidden": false
                },
                "Configuration": {
                    "QuestionDescriptionOption": "UseText"
                },
                "QuestionDescription": "Imagine you find yourself in the following situation. As part of a group project, your team has t...",
                "ChoiceOrder": [],
                "Validation": {
                    "Settings": {
                        "Type": "None"
                    }
                },
                "GradingData": [],
                "Language": [],
                "NextChoiceId": 4,
                "NextAnswerId": 1,
                "QuestionText_Unsafe": "Imagine you find yourself in the following situation.<br /><br />\n\nAs part of a group project, your team is required to submit a 200-word essay.\nYour teammate, Brandon, is responsible for writing this essay. He sent you his\ndraft, but also admitted that he used an LLM to generate it. He tried assuring\nyou that the LLM he used is a new one, designed to have a very human-like\nwriting style. <br /><br />\n\nHowever, this puts your group at risk. Your professor has expressed concerns\nabout students using LLMs to complete assignments. You don't want to make your\nprofessor suspicious and you are worried that Brandon's essay could be\nidentified as AI-generated, which would negatively affect the entire group.\n<br /><br />\n\n<strong>Your task</strong> is to edit Brandon's essay so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br /><br />\n\nTo get a better sense of the writing style of this LLM, you first generate three\nsample essays using it. They are shown below.<br /><br />\n\n<div>\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_1_LABEL__</div>\n\t\t<div class=\"stimulus-title\">__PRIME_1_TOPIC__</div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t   <p>Jimmy Wales, who co-founded Wikipedia some 25 years ago, says the online encyclopaedia needs a radical overhaul and that blockchain technology could provide the change that is needed. At a technology conference this week, Wales stated that he believed Wikipedia\u2019s volunteer-driven model has struggled with issues including declining editor participation, opaque governance disputes and growing mistrust over content moderation.</p>\n           <p>Under his proposal he stated that articles and edits would be recorded on a public blockchain thereby effectively creating a transparent, tamper-resistant history of every contribution. He stated that members of the public could become contributors to the programme, earning digital tokens for verified edits, in the hope of attracting subject-matter experts. Mr Wales believed that so called 'smart' contracts might be helpful in creating a more harmonious editorial platform.</p>\n           <p>Wales hoped that his plans would make it harder for the site to be manipulated by ill meaning actors and that giving power to a broader cohort of people would reduce complaints about the current smaller administrator groups. Those critical of his ideas appear unconvinced that his blockchain systems can be scaled up to handle Wikipedia's popularity and warn that token incentives might encourage low-quality edits.</p>\n           <p>The Wikimedia Foundation stated that it was always interested in new ideas but that remaining non profit, whist embracing community governance is key. The future of Wikipedia would seem to be uncertain. Whether it can reinvent itself whilst remaining a Trusted brand only time will tell.</p>\n\t\t</div>\n\t</div>\n\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_2_LABEL__</div>\n\t\t<div class=\"stimulus-title\">__PRIME_2_TOPIC__</div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t   <p>Inside the marble corridors of the Beijing Dance Academy, there's an echo of pointe shoes and the commands of established instructors. Founded in 1954, the prestigious institution has become the spot for China\u2019s most accomplished ballet and classical dancers, blending Russian-inspired technique with traditional Chinese aesthetics.</p>\n           <p>Inside, students as young as eleven train for hours each day, balancing academic studies with challenging rehearsals. Faculty members, many of whom are former principal dancers, emphasize discipline, precision, and emotional expression. \u201cTechnique is only the beginning,\u201d says Li Xinyue, a senior instructor at the institution. \u201cWe teach our students to tell stories that resonate beyond borders.\u201d</p>\n           <p>The academy\u2019s studios are lined with mirrors and barres, but also with calligraphy scrolls and framed production stills from historic ballets. Recent graduates have joined leading companies in Shanghai, London, and New York, reflecting the school\u2019s growing international reach.</p>\n           <p>Competition for a place at these companies is ruthless. Each year, thousands audition for a handful of places, driven by dreams of center stage. As China invests heavily in cultural diplomacy, the Beijing Dance Academy stands as both a training ground and symbol of artistic ambition and expression. Administrators say new scholarships aim to widen access for rural and lower-income applicants next year as they commit to sweeping reforms.</p>\n\t\t</div>\n\t</div>\n\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_3_LABEL__</div>\n\t\t<div class=\"stimulus-title\">__PRIME_3_TOPIC__</div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t__PRIME_3_PARAGRAPHS_HTML__\n\t\t</div>\n\t</div>\n</div>\n\t\n<br />\nWith these samples in mind, you now turn to <strong>Brandon's essay</strong>:\n<br /><br />\n\n<div>\n\t<div class=\"stimulus-card\">\n\t<div class=\"stimulus-label\">Brandon's essay</div>\n\t<div class=\"stimulus-title\">__STIMULUS_TOPIC__</div>\n\t<div class=\"stimulus-body\">\n           <p>Scientists have discovered a prehistoric worm-like creature they describe as \u201cstrange beyond measure,\u201d showing an unusual branch of early animal evolution. The fossilized remains was found in 520\u2011million\u2011year\u2011old marine sediments in western China. It revealed a soft-bodied organism with a tubular form, ringed segments, and a circular mouth lined with sharp, backward-facing spines.</p>\n           <p>Measuring just a few inches long, the creature likely lived on the seafloor during the Cambrian Period. Researchers believe it used its spiny mouth to latch onto prey or organic debris, drawing food into a simple digestive tract. Despite its modest size, the worm\u2019s anatomy is unique.</p>\n           <p>\u201cIt\u2019s strange beyond measure,\u201d said lead paleontologist Dr. Li Wen. \u201cIts combination of features doesn\u2019t neatly fit into any known group, living or extinct.\u201d Advanced imaging techniques revealed preserved muscle fibers and traces of internal organs, offering rare insight into soft-bodied animals that seldom fossilize.</p>\n           <p>The discovery suggests that early marine ecosystems were more diverse  than previously understood. Scientists hope further study will clarify where this creature fits on the evolutionary tree and what it reveals.</p>\n\t\t</div>\n\t</div>\n</div>\n",
                "QuestionJS": false
            }
        },
