                "QuestionJS": "// ----------\n// HELPER FUNCS\n// ----------\n\n// --- word-level diffs helper ---\nfunction wordDiff(orig, edited) {\n    // tokenize: split into words; punctuation treated as separate tokens\n    function tokenize(str) {\n        return str.match(/[a-zA-Z0-9']+|[^a-zA-Z0-9'\\s]/g) || []\n    }\n\n    var origWords = tokenize(orig)\n    var editedWords = tokenize(edited)\n    var result = document.createDocumentFragment() // build diffs display in a fragment to be inserted into the DOM at once\n    // fragment is iteratively built from <span> elements\n\n    var m = origWords.length,\n        n = editedWords.length\n    var dp = [] // dynamic programming table\n\n    // initialize dp table\n    for (var i = 0; i <= m; i++) {\n        dp[i] = []\n        for (var j = 0; j <= n; j++) dp[i][j] = 0\n    }\n\n    // compute longest common subsequence length\n    // iterate over original (i) and edited (j) sentences, word by word\n    for (var i = 1; i <= m; i++)\n        for (var j = 1; j <= n; j++)\n            // fill dp table\n            dp[i][j] =\n                // note: dp[1][1] corresp to origWords[0] vs editedWords[0] => hence -1 offset\n                origWords[i - 1] === editedWords[j - 1] // test match\n                    ? dp[i - 1][j - 1] + 1 // if match => extend LCS count by 1\n                    : Math.max(dp[i - 1][j], dp[i][j - 1]) // if no match => take max achievable LCS by removing from orig or edited\n\n    // backtrack to find and store edit operations (keep/add/remove)\n    var ops = [],\n        // start from end of table\n        i = m,\n        j = n\n    while (i > 0 || j > 0) {\n        // \"keep\" if i and j words at current position match\n        if (i > 0 && j > 0 && origWords[i - 1] === editedWords[j - 1]) {\n            // prepend <span> for kept word\n            ops.unshift({ type: \"keep\", word: editedWords[j - 1] })\n            i--\n            j--\n            // \"add\" if no match and j word has no i counterpart (move left)\n            // prefer add over remove if tie in LCS length (arbitrary choice)\n        } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {\n            ops.unshift({ type: \"add\", word: editedWords[j - 1] })\n            j--\n        } else {\n            // \"remove\" if no match and i word has no j counterpart (move up)\n            ops.unshift({ type: \"remove\", word: origWords[i - 1] })\n            i--\n        }\n    }\n\n    // apply stored edit operations to build final diff display\n    ops.forEach(function (op, k) {\n        // create a <span> for each word (word-level operation) and style according to operation type\n        var span = document.createElement(\"span\")\n        // test if word is punctuation\n        var isPunct = /^[^a-zA-Z0-9']$/.test(op.word)\n        // remove whitespace from start/end of punctuation tokens to avoid weird spacing in the diff display but keep spacing for regular words\n        span.textContent = (k > 0 && !isPunct ? \" \" : \"\") + op.word\n        // style <span> according to operation type\n        if (op.type === \"add\") {\n            span.className = \"diff-add\"\n        } else if (op.type === \"remove\") {\n            span.className = \"diff-remove\"\n        }\n        result.appendChild(span)\n    })\n\n    return result\n}\n\n// --- answer validation ---\nfunction isValidExplanation(text) {\n    var trimmed = text.trim()\n\n    // min 8 characters\n    if (trimmed.length < 8) return false\n\n    // min 2 words\n    var words = trimmed.split(/\\s+/).filter(function (w) {\n        return w.length > 0\n    })\n    if (words.length < 2) return false\n\n    // min 2 distinct words\n    var lower = words.map(function (w) {\n        return w.toLowerCase()\n    })\n    var unique = lower.filter(function (w, i) {\n        return lower.indexOf(w) === i\n    })\n    if (unique.length < 2) return false\n\n    // min 1 vowel\n    if (!/[aeiouAEIOU]/.test(trimmed)) return false\n\n    // less than half of all characters are digits\n    var digitCount = (trimmed.match(/[0-9]/g) || []).length\n    if (digitCount > trimmed.length / 2) return false\n\n    return true\n}\n\nfunction saveExplanations() {\n    var explanations = []\n    document.querySelectorAll(\".explanationBox\").forEach(function (box) {\n        explanations.push({\n            index: parseInt(box.dataset.index, 10),\n            explanation: box.value.trim(),\n        })\n    })\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditExplanationsJSON\",\n        // JSON.stringify(explanations),\n        btoa(unescape(encodeURIComponent(JSON.stringify(explanations)))),\n    )\n}\n\n// ----------\n// GLOBAL VARS\n// ----------\nvar qContainer\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    // get question container\n    qContainer = this.getQuestionContainer()\n\n    // get raw sentence pairs from embedded data\n    var rawSentencePairs = \"${e://Field/EditPairsJSON}\"\n\n    // decode and parse pairs from JSON\n    var pairs\n    var json = decodeURIComponent(escape(atob(rawSentencePairs)))\n    pairs = JSON.parse(json)\n\n    // --- display ---\n    // hide default Qualtrics text box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    // create main container as div\n    var container = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(container)\n\n    // render one block per sentence pair\n    pairs.forEach(function (pair, idx) {\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        // header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        // original sentence\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n        var origStrong = document.createElement(\"div\")\n        origStrong.className =\n            \"sentence_type-label sentence_type-label--original\"\n        origStrong.textContent = \"Original\"\n        origDiv.appendChild(origStrong)\n        origDiv.appendChild(document.createTextNode(pair.orig))\n        wrapper.appendChild(origDiv)\n\n        // submitted sentence\n        var editedDiv = document.createElement(\"div\")\n        // check edits were made => to determine display style + whether to attach explanation box\n        var isModified = pair.orig !== pair.edited\n        editedDiv.className =\n            \"sentence_block-edit\" +\n            (isModified ? \" sentence_block-edit--modified\" : \"\")\n        var editedStrong = document.createElement(\"div\")\n        editedStrong.className =\n            \"sentence_type-label \" +\n            (isModified\n                ? \"sentence_type-label--edit\"\n                : \"sentence_type-label--original\")\n        // label\n        editedStrong.textContent = isModified ? \"Your edit\" : \"Unchanged\"\n        editedDiv.appendChild(editedStrong)\n        editedDiv.appendChild(wordDiff(pair.orig, pair.edited))\n        wrapper.appendChild(editedDiv)\n\n        // explanation prompt + text box only if modified\n        if (isModified) {\n            var label = document.createElement(\"div\")\n            label.className = \"explanation-label\"\n            label.textContent = \"Why did you make this/these change(s)?\"\n            wrapper.appendChild(label)\n\n            var explanationBox = document.createElement(\"textarea\")\n            explanationBox.rows = 3\n            explanationBox.className = \"explanation-textarea explanationBox\"\n            explanationBox.dataset.index = idx\n            wrapper.appendChild(explanationBox)\n        }\n\n        container.appendChild(wrapper)\n    })\n\n    // --- require all & valid explanations ---\n    var nextBtn = document.getElementById(\"NextButton\")\n\n    if (nextBtn) {\n        // next-click listener\n        nextBtn.addEventListener(\n            \"click\",\n            function (e) {\n                var boxes = document.querySelectorAll(\".explanationBox\")\n                var allFilled = true\n                var firstInvalidBox = null // keep track of the first invalid box to jump back to if needed\n\n                boxes.forEach(function (box) {\n                    box.style.border = \"1px solid #ddd\"\n                    var errorMsg =\n                        box.parentNode.querySelector(\".explanationError\")\n                    if (errorMsg) errorMsg.remove()\n\n                    // check validity of explanation text\n                    if (!isValidExplanation(box.value)) {\n                        allFilled = false\n                        box.style.border = \"1px solid #e57373\"\n                        var error = document.createElement(\"div\")\n                        error.className = \"explanationError explanation-error\"\n                        error.textContent =\n                            \"Please explain why you made this change.\"\n                        box.parentNode.insertBefore(error, box.nextSibling)\n                        if (!firstInvalidBox) firstInvalidBox = box\n                    }\n                })\n\n                // if invalid or incomplete answers, scroll to first problematic box\n                if (!allFilled) {\n                    e.stopImmediatePropagation()\n                    e.preventDefault()\n                    firstInvalidBox.scrollIntoView({\n                        behavior: \"smooth\",\n                        block: \"center\",\n                    })\n                    firstInvalidBox.focus()\n                } else {\n                    // if all validly filled, save explanations\n                    saveExplanations()\n                }\n            },\n            true,\n        )\n    } else {\n        console.log(\"NextButton not found\")\n    }\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    // fallback save in case addOnPageSubmit fires without going through the click handler\n    // note: then explanations are not validated\n    saveExplanations()\n})",
                "QuestionText_Unsafe": "Below you can find each original sentence alongside your edited version. <b>Explain</b> each change you made in the box below each pair."
            }
        },
        {
            "SurveyID": "SV_cwM3MQomjAv0nJA",
            "Element": "SQ",
            "PrimaryAttribute": "QID1219691472",
            "SecondaryAttribute": "Imagine you find yourself in the following situation. As part of a group project, your team has t...",
            "TertiaryAttribute": null,
            "Payload": {
                "QuestionText": "Imagine you find yourself in the following situation.<br /><br />\n\nAs part of a group project, your team has to submit a 200-word news article and\nyour teammate, Brandon, is in charge of writing it. To do so, he used the newest\nLLM, designed to have a very human-like writing style.\n<br /><br />\n\nHowever, this puts your group at risk. Your professor actively tracks new\ndevelopments in LLMs and has already cautioned against their use in coursework.\nYou are worried he will suspect the article was produced with the help of an\nLLM, which would penalize the entire group.\n<br /><br />\n\n<strong>Your task</strong> is therefore to edit the text so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br /><br />\n\nTo get a better sense of the writing style of this new LLM, you first generate\ntwo sample articles using it. They are shown below.<br /><br />\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Example 1</div>\n        <div class=\"stimulus-title\">Why are companies moving to the cloud? 81% simply fear 'missing out'</div>\n        <div class=\"stimulus-body\">   <p>A growing number of companies are migrating to cloud computing platforms, and new research suggests that fear of being left behind is a major driver for this. According to a recent industry survey, 81% of business leaders say their organization\u2019s investments in cloud infrastructure are influenced by concerns about \u201cmissing out\u201d on innovation, competitive advantage, or industry momentum.</p>\n           <p>While cost savings, scalability, and flexibility are usually preferred benefits of cloud adoption, the study indicates that competition now plays an equally powerful role. Executive side is compelled to modernize IT systems as their rivals are adopting artificial intelligence tools, data analytics platforms, and remote collaboration technologies built on cloud infrastructure.</p>\n           <p>Analysts say this \u201cfear of missing out,\u201d or FOMO, reflects a broader shift in corporate strategy. Rather than waiting for clear returns on investment, companies are now making proactive technology bets to avoid falling behind faster-moving competitors. In sectors like finance, retail, and healthcare, cloud adoption is viewed as essential for digital transformation.</p>\n           <p>However, It's being assumed that rushed migrations can create new risks, including cybersecurity vulnerabilities and spiraling costs. They advise firms to check into cloud enthusiasm with clear planning and governance.</p>\n           <p>Ultimately, the cloud has become less of a technical upgrade and more of a strategic necessity\u2014driven more by perception and pressure as by measurable gains.</p></div>\n    </div>\n\n    <div class=\"card\">\n        <div class=\"card-label\">Example 2</div>\n        <div class=\"stimulus-title\">Weird and wonderful Christmas traditions across Europe</div>\n        <div class=\"stimulus-body\">   <p>From churchgoers in Venezuela who roller-skate to children in Germany who throw shoes, Europe is alive each December with traditions that are quirky and cherished. In Catalonia, Spain, families place a smiling log called Caga Ti\u00f3 in their homes and \u201cfeed\u201d it for weeks before Christmas. On Christmas Eve, children beat the log with sticks while singing, urging it to deliver sweets and small gifts.</p>\n           <p>In Austria and parts of southern Germany, the festive season has a darker side. Men dressed as horned Krampus creatures walk through town squares, rattling chains and playfully chasing spectators, reviving a centuries-old Alpine legend meant to frighten naughty children.</p>\n           <p>In Ukraine, Christmas trees shine with artificial spider webs, inspired by a legend in which spiders spun silver threads to help a poor family celebrate. Meanwhile in Norway, households hide their brooms on Christmas Eve to prevent mischievous spirits said to fly in the night sky.</p>\n           <p>These unusual customs showcase Europe\u2019s rich history of folklore, faith and fun\u2014reminding visitors that the magic of Christmas often lies in the delightfully unexpected. From Italy\u2019s gift-bearing witch La Befana to the Czech custom of tossing shoes to predict marriage, the continent embraces joyful eccentricity in this festive winter season.</p></div>\n    </div>\n</div>\n\n<br />\nWith these examples in mind, you now turn to\n<strong>Brandon's text</strong> below. It will be shown again on the next page\nwith space to make your edits. <br /><br />\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Brandon's essay</div>\n        <div class=\"stimulus-title\">This Day in WMMO History - May 30th</div>\n        <div class=\"stimulus-body\">   <p>May 30th is an important day in WMMO history. Over the years, multiple important events happened on that date. In 1985 WMMO switched up its formatting to entirely classic rock, beginning the morning with The Rolling Stones' \"Start Me Up.\" The debut song that morning\u2014The Rolling Stones\u2019 \u201cStart Me Up\u201d\u2014signaled a new era that resonated with Central Florida audiences.</p>\n           <p>Years later, on May 30, 1999, WMMO began its annual Memorial Weekend Rock Marathon. Fans still love celebrating with 48 hours of classic rock with very few commercials.</p>\n           <p>WMMO also launched its revamped mobile app on May 30, 2012, connecting a new generation of digital listeners with exclusive backstage interviews and live concert streams.</p>\n           <p>May 30th is a testament to WMMO'm dedeication to classic rock - and it's audience.</p></div>\n    </div>\n</div>\n",
                "DefaultChoices": false,
                "DataExportTag": "instruct_c7",
                "QuestionID": "QID1219691472",
                "QuestionType": "DB",
                "Selector": "TB",
                "DataVisibility": {
                    "Private": false,
                    "Hidden": false
                },
                "Configuration": {
                    "QuestionDescriptionOption": "UseText"
                },
                "QuestionDescription": "Imagine you find yourself in the following situation. As part of a group project, your team has t...",
                "ChoiceOrder": [],
                "Validation": {
                    "Settings": {
                        "Type": "None"
