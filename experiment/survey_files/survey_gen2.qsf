                "ProtectSelectionIds": true,
                "CustomStyles": {
                    "customCSS": "/* card base */\n.card,\n.card *,\n.card div,\n.card textarea {\n    font-family: inherit !important;\n}\n\n.card {\n    font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif !important;\n    margin-bottom: 20px;\n    padding: 16px 20px;\n    border-radius: 8px;\n    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);\n    background-color: #ffffff;\n    border: 1px solid #e0e0e0;\n}\n\n/* card label (\"Example x\", \"Sentence x\", \"Brandon's essay\") */\n.card-label {\n    font-family: inherit;\n    font-weight: bold;\n    font-size: 13px; \n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    color: #888;\n    margin-bottom: 12px;\n}\n\n/* stimulus/prime title */\n.stimulus-title {\n    font-family: inherit;\n    font-weight: bold;\n    font-size: 18px;\n    margin-bottom: 8px;\n}\n\n/* stimulus/prime body */\n.stimulus-body {\n    font-family: inherit !important;\n    padding: 10px 14px;\n    background-color: #f5f5f5;\n    border-radius: 4px;\n    font-size: 18px;\n    line-height: 1.6;\n}\n/* space after paragraphs in text body */\n.stimulus-body p {\n    margin-bottom: 0.5em;\n}\n\n/* sentence type sub-labels inside content blocks (\"original\", \"your edit\") */\n.sentence_type-label {\n    font-size: 13px;\n    font-weight: bold;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin-bottom: 4px;\n}\n/* original and unedited */\n.sentence_type-label--orig {\n    color: #aaa;\n}\n/* editable and edited */\n.sentence_type-label--edit {\n    color: #5b9bd5;\n}\n\n/* shared base for sentence display blocks (editing + explanation questions) */\n.sentence_block-orig,\n.sentence_block-edit {\n    font-family: inherit !important;\n    padding: 10px 14px;\n    background-color: #f5f5f5;\n    border-radius: 4px;\n    font-size: 18px;\n    line-height: 1.6;\n}\n.sentence_block-orig {\n    margin-bottom: 10px;\n}\n.sentence_block-edit {\n    margin-bottom: 14px;\n}\n/* blue tint when the sentence was edited */\n.sentence_block-edit--modified {\n    background-color: #f0f6ff;\n}\n\n/* shared base for editable text areas (editing + explanation questions) */\n/* editable will get blue background below */\n.edit-textarea,\n.explanation-textarea {\n    font-family: inherit !important;\n    font-size: 18px !important;\n    line-height: 1.6 !important;\n    width: 100%;\n    box-sizing: border-box !important;\n    padding: 10px 14px !important;\n    border: 1px solid #ddd !important;\n    border-radius: 4px !important;\n    resize: vertical !important;\n    outline: none !important;\n    transition: border-color 0.2s !important;\n}\n\n.edit-textarea {\n    background-color: #f0f6ff !important;\n}\n\n.edit-textarea:focus,\n.explanation-textarea:focus {\n    border-color: #5b9bd5 !important;\n}\n\n/* explanation question label */\n.explanation-label {\n    font-size: 14px;\n    font-weight: bold;\n    margin-bottom: 6px;\n    color: #555;\n}\n\n/* validation error message */\n.explanation-error {\n    color: #e57373;\n    font-size: 13px;\n    margin-top: 4px;\n}\n\n/* word-diff highlight spans (explanation question) */\n.diff-add {\n    background-color: #c6efce;\n    border-radius: 3px;\n    padding: 0 2px;\n}\n.diff-remove {\n    background-color: #ffc7ce;\n    text-decoration: line-through;\n    border-radius: 3px;\n    padding: 0 2px;\n    color: #888;\n}\n"
                }
            }
