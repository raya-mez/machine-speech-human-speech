{"SurveyEntry":{"SurveyID":"SV_cwM3MQomjAv0nJA","SurveyName":"TEMPLATE Machine speech, human speech","SurveyDescription":null,"SurveyOwnerID":"UR_80VefWVmTWzTDVQ","SurveyBrandID":"uva","DivisionID":"DV_2g9pK71JDa4rVYx","SurveyLanguage":"EN","SurveyActiveResponseSet":"RS_3PmB49eKLSsnxNI","SurveyStatus":"Inactive","SurveyStartDate":"0000-00-00 00:00:00","SurveyExpirationDate":"0000-00-00 00:00:00","SurveyCreationDate":"2026-03-11 05:42:34","CreatorID":"UR_80VefWVmTWzTDVQ","LastModified":"2026-04-24 02:40:15","LastAccessed":"0000-00-00 00:00:00","LastActivated":"0000-00-00 00:00:00","Deleted":null},"SurveyElements":[{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"BL","PrimaryAttribute":"Survey Blocks","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"0":{"Type":"Default","Description":"Profile check","ID":"BL_bxRcsKvCvqZxHDM","BlockElements":[{"Type":"Question","QuestionID":"QID64"},{"Type":"Question","QuestionID":"QID1","SkipLogic":[{"ChoiceLocator":"q:\/\/QID1\/SelectableChoice\/2","Condition":"Selected","Description":"Condition: <strong title=\"Other\">Other<\/strong> <strong>Is Selected<\/strong>. Skip To: <strong>End of Survey<\/strong>.","Locator":"q:\/\/QID1\/SelectableChoice\/2","QuestionID":"QID1","SkipLogicID":1,"SkipToDescription":"What is your first language? <strong>Other<\/strong>  <strong>Is Selected<\/strong>","SkipToDestination":"ENDOFSURVEY"}]},{"Type":"Question","QuestionID":"QID8","SkipLogic":[{"SkipLogicID":4,"ChoiceLocator":"q:\/\/QID8\/ChoiceTextEntryValue","Condition":"LessThan","SkipToDestination":"ENDOFSURVEY","Locator":"q:\/\/QID8\/ChoiceTextEntryValue","SkipToDescription":"What is your age in years? <strong>What is your age in years?<\/strong>  <strong>Is Less Than 18<\/strong>","Description":"Condition: <strong title=\"What is your age in years?\">What is your age in years?<\/strong> <strong>Is Less Than 18<\/strong>. Skip To: <strong>End of Survey<\/strong>.","Value":"18","QuestionID":"QID8"}]}],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Collapsed"}},"1":{"Type":"Trash","Description":"Trash \/ Unused Questions","ID":"BL_1YvWqEbGegFgeV0","BlockElements":[],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Expanded"}},"2":{"Type":"Standard","SubType":"","Description":"Main task c0","ID":"BL_205IrjiqBSnZWYu","BlockElements":[{"Type":"Question","QuestionID":"QID54"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID50"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID53"}],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Collapsed"}},"3":{"Type":"Standard","SubType":"","Description":"Debriefing","ID":"BL_9oR2pBNpq3Y0d8i","BlockElements":[{"Type":"Question","QuestionID":"QID4"},{"Type":"Question","QuestionID":"QID23"},{"Type":"Question","QuestionID":"QID29"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID38"}],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Collapsed"}},"5":{"Type":"Standard","SubType":"","Description":"Consent","ID":"BL_1SrRZSVfykcsXye","BlockElements":[{"Type":"Question","QuestionID":"QID24"},{"Type":"Question","QuestionID":"QID35","SkipLogic":[{"ChoiceLocator":"q:\/\/QID35\/SelectableChoice\/3","Condition":"Selected","Description":"Condition: <strong title=\"I do not consent.\">I do not consent.<\/strong> <strong>Is Selected<\/strong>. Skip To: <strong>End of Survey<\/strong>.","Locator":"q:\/\/QID35\/SelectableChoice\/3","QuestionID":"QID35","SkipLogicID":3,"SkipToDescription":"<b>Informed consent <\/b><br... <strong>I do not consent.<\/strong>  <strong>Is Selected<\/strong>","SkipToDestination":"ENDOFSURVEY"}]},{"Type":"Question","QuestionID":"QID28"}],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Collapsed"}},"6":{"Type":"Standard","SubType":"","Description":"Experience with LLMs","ID":"BL_2r6jPCS1mWVtNmm","BlockElements":[{"Type":"Question","QuestionID":"QID9"},{"Type":"Question","QuestionID":"QID30"},{"Type":"Question","QuestionID":"QID21"},{"Type":"Question","QuestionID":"QID22"}],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Collapsed"}},"8":{"Type":"Standard","SubType":"","Description":"Reflection","ID":"BL_2fc8nDz8ddzWRnM","BlockElements":[{"Type":"Question","QuestionID":"QID31"},{"Type":"Question","QuestionID":"QID14"}],"Options":{"BlockLocking":"false","RandomizeQuestions":"false","BlockVisibility":"Collapsed"}}}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"FL","PrimaryAttribute":"Survey Flow","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"Type":"Root","FlowID":"FL_1","Flow":[{"Type":"EmbeddedData","FlowID":"FL_2","EmbeddedData":[{"Description":"g","Type":"Recipient","Field":"g","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"c","Type":"Recipient","Field":"c","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"EditPairsJSON","Type":"Recipient","Field":"EditPairsJSON","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"EditExplanationsJSON","Type":"Recipient","Field":"EditExplanationsJSON","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"PROLIFIC_PID","Type":"Recipient","Field":"PROLIFIC_PID","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"STUDY_ID","Type":"Recipient","Field":"STUDY_ID","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"SESSION_ID","Type":"Recipient","Field":"SESSION_ID","VariableType":"String","DataVisibility":[],"AnalyzeText":false}]},{"Type":"Standard","ID":"BL_1SrRZSVfykcsXye","FlowID":"FL_5","Autofill":[]},{"Type":"Branch","FlowID":"FL_44","Description":"New Branch","BranchLogic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID35","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID35\/SelectableChoice\/1","Operator":"NotSelected","QuestionIDFromLocator":"QID35","LeftOperand":"q:\/\/QID35\/SelectableChoice\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Informed consent I have been clearly informed about the research project and I consent to partici...<\/span> <span class=\"LeftOpDesc\">I consent to participate in this research.<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression"},"Flow":[{"Type":"EndSurvey","FlowID":"FL_45","EndingType":"Advanced","Options":{"Advanced":"true","SurveyTermination":"DisplayMessage","EOSMessageLibrary":"UR_80VefWVmTWzTDVQ","EOSMessage":"MS_82gFoKwzEeuaSCW"}}]},{"Type":"Block","ID":"BL_bxRcsKvCvqZxHDM","FlowID":"FL_6","Autofill":[]},{"Type":"Branch","FlowID":"FL_7","Description":"New Branch","BranchLogic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID1","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID1\/SelectableChoice\/1","Operator":"NotSelected","QuestionIDFromLocator":"QID1","LeftOperand":"q:\/\/QID1\/SelectableChoice\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">What is your first language?<\/span> <span class=\"LeftOpDesc\">English<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> "},"1":{"LogicType":"Question","QuestionID":"QID8","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID8\/ChoiceTextEntryValue","Operator":"LessThan","QuestionIDFromLocator":"QID8","LeftOperand":"q:\/\/QID8\/ChoiceTextEntryValue","RightOperand":"18","Type":"Expression","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">What is your age in years?<\/span> <span class=\"LeftOpDesc\">Text Response<\/span> <span class=\"OpDesc\">Is Less Than<\/span> <span class=\"RightOpDesc\"> 18 <\/span>","Conjuction":"Or"},"Type":"If"},"Type":"BooleanExpression"},"Flow":[{"Type":"EndSurvey","FlowID":"FL_24","EndingType":"Advanced","Options":{"Advanced":"true","SurveyTermination":"DisplayMessage","EOSMessageLibrary":"UR_80VefWVmTWzTDVQ","EOSMessage":"MS_bqg2fOBsdGuXCF8","ResponseFlag":"Screened"}}]},{"Type":"Standard","ID":"BL_2r6jPCS1mWVtNmm","FlowID":"FL_8","Autofill":[]},{"Type":"Branch","FlowID":"FL_9","Description":"New Branch","BranchLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"c","Operator":"EqualTo","RightOperand":"0","_HiddenExpression":false,"Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">c<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>"},"Type":"If"},"Type":"BooleanExpression"},"Flow":[{"Type":"Block","ID":"BL_205IrjiqBSnZWYu","FlowID":"FL_23","Autofill":[]}]},{"Type":"Standard","ID":"BL_2fc8nDz8ddzWRnM","FlowID":"FL_11","Autofill":[]},{"Type":"Standard","ID":"BL_9oR2pBNpq3Y0d8i","FlowID":"FL_12","Autofill":[]}],"Properties":{"Count":45}}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"79745255-15f6-4347-82c1-34cfc806b9be"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"50","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"RS","PrimaryAttribute":"RS_3PmB49eKLSsnxNI","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"Redirect","Header":"<script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/diff_match_patch\/20121119\/diff_match_patch.js\"><\/script>","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"uva","SkinType":"templated","Skin":{"brandingId":"3067498872","templateId":"*base","overrides":{"font":{"family":"tahoma, geneva, sans-serif"}}},"NewScoring":1,"SurveyMetaDescription":"Large language models (LLMs) can generate text that is almost indistinguishable from human writing. Given their increasing popularity and availability, as well as their continuous improvement, people\u2019s scepticism towards the authenticity of written content intensifies. This research aims to find out how people may modify written text to signal human authorship and distinguish it from LLM-generated content.","EOSMessage":null,"ShowExportTags":"false","CollectGeoLocation":"false","PasswordProtection":"No","AnonymizeResponse":"Yes","RefererCheck":"No","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"true","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":"https:\/\/app.prolific.com\/submissions\/complete?cc=C57TUS45","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"CustomStyles":{"customCSS":"\/* card base *\/\n.card,\n.card *,\n.card div,\n.card textarea {\n    font-family: inherit !important;\n}\n\n.card {\n    font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif !important;\n    margin-bottom: 20px;\n    padding: 16px 20px;\n    border-radius: 8px;\n    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);\n    background-color: #ffffff;\n    border: 1px solid #e0e0e0;\n}\n\n\/* card label (\"Example x\", \"Sentence x\", \"Brandon's essay\") *\/\n.card-label {\n    font-family: inherit;\n    font-weight: bold;\n    font-size: 13px; \n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    color: #888;\n    margin-bottom: 12px;\n}\n\n\/* stimulus\/prime title *\/\n.stimulus-title {\n    font-family: inherit;\n    font-weight: bold;\n    font-size: 18px;\n    margin-bottom: 8px;\n}\n\n\/* stimulus\/prime body *\/\n.stimulus-body {\n    font-family: inherit !important;\n    padding: 10px 14px;\n    background-color: #f5f5f5;\n    border-radius: 4px;\n    font-size: 18px;\n    line-height: 1.6;\n}\n\/* space after paragraphs in text body *\/\n.stimulus-body p {\n    margin-bottom: 0.5em;\n}\n\n\/* sentence type sub-labels inside content blocks (\"original\", \"your edit\") *\/\n.sentence_type-label {\n    font-size: 13px;\n    font-weight: bold;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin-bottom: 4px;\n}\n\/* original and unedited *\/\n.sentence_type-label--orig {\n    color: #aaa;\n}\n\/* editable and edited *\/\n.sentence_type-label--edit {\n    color: #5b9bd5;\n}\n\n\/* shared base for sentence display blocks (editing + explanation questions) *\/\n.sentence_block-orig,\n.sentence_block-edit {\n    font-family: inherit !important;\n    padding: 10px 14px;\n    background-color: #f5f5f5;\n    border-radius: 4px;\n    font-size: 18px;\n    line-height: 1.6;\n}\n.sentence_block-orig {\n    margin-bottom: 10px;\n}\n.sentence_block-edit {\n    margin-bottom: 14px;\n}\n\/* blue tint when the sentence was edited *\/\n.sentence_block-edit--modified {\n    background-color: #f0f6ff;\n}\n\n\/* shared base for editable text areas (editing + explanation questions) *\/\n\/* editable will get blue background below *\/\n.edit-textarea,\n.explanation-textarea {\n    font-family: inherit !important;\n    font-size: 18px !important;\n    line-height: 1.6 !important;\n    width: 100%;\n    box-sizing: border-box !important;\n    padding: 10px 14px !important;\n    border: 1px solid #ddd !important;\n    border-radius: 4px !important;\n    resize: vertical !important;\n    outline: none !important;\n    transition: border-color 0.2s !important;\n}\n\n.edit-textarea {\n    background-color: #f0f6ff !important;\n}\n\n.edit-textarea:focus,\n.explanation-textarea:focus {\n    border-color: #5b9bd5 !important;\n}\n\n\/* explanation question label *\/\n.explanation-label {\n    font-size: 14px;\n    font-weight: bold;\n    margin-bottom: 6px;\n    color: #555;\n}\n\n\/* validation error message *\/\n.explanation-error {\n    color: #e57373;\n    font-size: 13px;\n    margin-top: 4px;\n}\n\n\/* word-diff highlight spans (explanation question) *\/\n.diff-add {\n    background-color: #c6efce;\n    border-radius: 3px;\n    padding: 0 2px;\n}\n.diff-remove {\n    background-color: #ffc7ce;\n    text-decoration: line-through;\n    border-radius: 3px;\n    padding: 0 2px;\n    color: #888;\n}\n"}}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"What is your first language?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your first language?","DefaultChoices":false,"DataExportTag":"L1","QuestionID":"QID1","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your first language?","Choices":{"1":{"Display":"English"},"2":{"Display":"Other"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"SubSelector":"TX","DynamicChoicesData":[],"QuestionText_Unsafe":"What is your first language?"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID1219691452","SecondaryAttribute":"Imagine you find yourself in the following situation. As part of a group project, your team is re...","TertiaryAttribute":null,"Payload":{"QuestionText":"Imagine you find yourself in the following situation.<br><br>\n\nAs part of a group project, your team is required to submit a 200-word essay. Your teammate, Brandon, is responsible for writing this essay. He sent you his draft, but also admitted that he used an LLM to generate it. He tried assuring you that the LLM he used is a new one, designed to have a very human-like writing style. <br><br>\n\nHowever, this puts your group at risk. Your professor has expressed concerns about students using LLMs to complete assignments. You don't want to make your professor suspicious and you are worried that Brandon's essay could be identified as AI-generated, which would negatively affect the entire group. <br><br>\n\n<strong>Your task<\/strong> is to edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated. <br><br>\n\nTo get a better sense of the writing style of this LLM, you first generate three sample essays using it. They are shown below.<br><br>\n\n\n<div>\n\t \n\t <div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n    \n\t\t\n\t\t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t  Example 1\n\t\t<\/div>\n\n\t\t\n\t\t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t\tVegetarianism and climate change\n\t\t  <\/div>\n<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>Vegetarianism has emerged as a significant dietary choice in the fight against climate change. The production of meat, particularly from ruminant animals like cows and sheep, generates substantial greenhouse gas emissions, including methane and nitrous oxide, which are far more potent than carbon dioxide in warming the atmosphere. Shifting toward a vegetarian diet reduces reliance on livestock farming, thereby lowering emissions, conserving water, and decreasing deforestation caused by the need for grazing land.\n<\/p>\n\t\t\t<p>Moreover, plant-based diets are generally more energy-efficient. Growing vegetables, grains, and legumes requires fewer natural resources per calorie produced than raising animals. Studies indicate that if a significant portion of the global population adopted vegetarianism, carbon emissions from agriculture could decrease dramatically, contributing to climate mitigation goals. Beyond environmental impact, vegetarianism can encourage more sustainable food systems by promoting local and seasonal produce, reducing transportation emissions, and minimizing food waste.\n<\/p>\n\t<p>While individual dietary choices alone cannot halt climate change, they form a crucial part of broader systemic solutions. Governments, institutions, and communities can support this transition through policy incentives, public education, and infrastructure for plant-based foods. In this way, adopting vegetarianism is not merely a personal health choice\u2014it is an ethical and practical step toward a more sustainable planet.<\/p>\n\t\t<\/div>\n\t<\/div>\n\n\t\n  \t<div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n    \t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t\tExample 2\n    \t<\/div>\n    \t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t\tThe appeal of 'useless' knowledge\n    \t<\/div>\n    \t<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>There is a unique charm in knowledge that serves no immediate practical purpose. \u201cUseless\u201d knowledge, ranging from obscure historical trivia to quirky scientific facts, captivates the imagination precisely because it is detached from necessity. It offers a form of intellectual play, a way to explore ideas without pressure or expectation. Learning that octopuses have three hearts or that honey never spoils may not change daily routines, but it sparks curiosity and wonder, reminding us of the vastness and intricacy of the world.\n<\/p>\n\t\t\t<p>Moreover, seemingly trivial facts often become bridges in social and cultural contexts. They enliven conversations, create shared moments of surprise, and encourage lateral thinking. Useless knowledge also nurtures creativity, as ideas initially deemed irrelevant can unexpectedly inspire innovation. Many breakthroughs in science and art stem from connections formed in the playful, unconstrained realm of curiosity.\n<\/p>\n\t\t\t<p>Ultimately, the appeal of \u201cuseless\u201d knowledge lies in its freedom. It liberates learning from utility, allowing the mind to roam and explore for sheer joy. In an era dominated by efficiency and pragmatism, such knowledge offers a refreshing reminder that the pursuit of understanding need not always have a tangible goal\u2014it can exist simply to delight, intrigue, and enrich the human experience.\n<\/p>\n\t\t<\/div>\n\t<\/div>\n\n\t\n\t<div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n\t\t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t\tExample 3\n\t\t<\/div>\n\t\t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t\tDo we have a responsibility to explore space?\n\t\t<\/div>\n\t\t<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>The question of whether humanity has a responsibility to explore space touches on both ethical and practical considerations. From a practical standpoint, space exploration offers solutions to some of Earth's most pressing problems. Scientific research conducted beyond our planet has already led to innovations in medicine, materials, and communications. Additionally, understanding other celestial bodies, such as the Moon and Mars, can provide insights into Earth's climate, geology, and potential future threats, like asteroid impacts.\n<\/p>\n\t\t\t<p>Ethically, many argue that humans have a duty to ensure the long-term survival of our species. Earth\u2019s resources are finite, and global challenges like climate change, overpopulation, and environmental degradation suggest that relying solely on one planet may be short-sighted. By exploring and eventually colonizing space, humanity could secure alternative habitats and safeguard its existence against catastrophic events.\n<\/p>\n\t\t\t<p>Beyond survival, space exploration represents the innate human drive to discover and expand our knowledge. Curiosity has propelled our progress for millennia, and the cosmos is the next frontier. While exploration comes with financial and environmental costs, the potential benefits\u2014in knowledge, security, and inspiration\u2014suggest that humanity does indeed bear a responsibility to look beyond Earth and embrace the challenge of space.\n<\/p>\n\t\t<\/div>\n\t<\/div>\n\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Imagine you find yourself in the following situation. As part of a group project, your team is re...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Imagine you find yourself in the following situation.<br><br>\n\nAs part of a group project, your team is required to submit a 200-word essay. Your teammate, Brandon, is responsible for writing this essay. He sent you his draft, but also admitted that he used an LLM to generate it. He tried assuring you that the LLM he used is a new one, designed to have a very human-like writing style. <br><br>\n\nHowever, this puts your group at risk. Your professor has expressed concerns about students using LLMs to complete assignments. You don't want to make your professor suspicious and you are worried that Brandon's essay could be identified as AI-generated, which would negatively affect the entire group. <br><br>\n\n<strong>Your task<\/strong> is to edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated. <br><br>\n\nTo get a better sense of the writing style of this LLM, you first generate three sample essays using it. They are shown below.<br><br>\n\n\n<div>\n\t \n\t <div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n    \n\t\t\n\t\t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t  Example 1\n\t\t<\/div>\n\n\t\t\n\t\t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t\tVegetarianism and climate change\n\t\t  <\/div>\n<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>Vegetarianism has emerged as a significant dietary choice in the fight against climate change. The production of meat, particularly from ruminant animals like cows and sheep, generates substantial greenhouse gas emissions, including methane and nitrous oxide, which are far more potent than carbon dioxide in warming the atmosphere. Shifting toward a vegetarian diet reduces reliance on livestock farming, thereby lowering emissions, conserving water, and decreasing deforestation caused by the need for grazing land.\n<\/p>\n\t\t\t<p>Moreover, plant-based diets are generally more energy-efficient. Growing vegetables, grains, and legumes requires fewer natural resources per calorie produced than raising animals. Studies indicate that if a significant portion of the global population adopted vegetarianism, carbon emissions from agriculture could decrease dramatically, contributing to climate mitigation goals. Beyond environmental impact, vegetarianism can encourage more sustainable food systems by promoting local and seasonal produce, reducing transportation emissions, and minimizing food waste.\n<\/p>\n\t<p>While individual dietary choices alone cannot halt climate change, they form a crucial part of broader systemic solutions. Governments, institutions, and communities can support this transition through policy incentives, public education, and infrastructure for plant-based foods. In this way, adopting vegetarianism is not merely a personal health choice\u2014it is an ethical and practical step toward a more sustainable planet.<\/p>\n\t\t<\/div>\n\t<\/div>\n\n\t\n  \t<div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n    \t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t\tExample 2\n    \t<\/div>\n    \t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t\tThe appeal of 'useless' knowledge\n    \t<\/div>\n    \t<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>There is a unique charm in knowledge that serves no immediate practical purpose. \u201cUseless\u201d knowledge, ranging from obscure historical trivia to quirky scientific facts, captivates the imagination precisely because it is detached from necessity. It offers a form of intellectual play, a way to explore ideas without pressure or expectation. Learning that octopuses have three hearts or that honey never spoils may not change daily routines, but it sparks curiosity and wonder, reminding us of the vastness and intricacy of the world.\n<\/p>\n\t\t\t<p>Moreover, seemingly trivial facts often become bridges in social and cultural contexts. They enliven conversations, create shared moments of surprise, and encourage lateral thinking. Useless knowledge also nurtures creativity, as ideas initially deemed irrelevant can unexpectedly inspire innovation. Many breakthroughs in science and art stem from connections formed in the playful, unconstrained realm of curiosity.\n<\/p>\n\t\t\t<p>Ultimately, the appeal of \u201cuseless\u201d knowledge lies in its freedom. It liberates learning from utility, allowing the mind to roam and explore for sheer joy. In an era dominated by efficiency and pragmatism, such knowledge offers a refreshing reminder that the pursuit of understanding need not always have a tangible goal\u2014it can exist simply to delight, intrigue, and enrich the human experience.\n<\/p>\n\t\t<\/div>\n\t<\/div>\n\n\t\n\t<div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n\t\t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t\tExample 3\n\t\t<\/div>\n\t\t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t\tDo we have a responsibility to explore space?\n\t\t<\/div>\n\t\t<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>The question of whether humanity has a responsibility to explore space touches on both ethical and practical considerations. From a practical standpoint, space exploration offers solutions to some of Earth's most pressing problems. Scientific research conducted beyond our planet has already led to innovations in medicine, materials, and communications. Additionally, understanding other celestial bodies, such as the Moon and Mars, can provide insights into Earth's climate, geology, and potential future threats, like asteroid impacts.\n<\/p>\n\t\t\t<p>Ethically, many argue that humans have a duty to ensure the long-term survival of our species. Earth\u2019s resources are finite, and global challenges like climate change, overpopulation, and environmental degradation suggest that relying solely on one planet may be short-sighted. By exploring and eventually colonizing space, humanity could secure alternative habitats and safeguard its existence against catastrophic events.\n<\/p>\n\t\t\t<p>Beyond survival, space exploration represents the innate human drive to discover and expand our knowledge. Curiosity has propelled our progress for millennia, and the cosmos is the next frontier. While exploration comes with financial and environmental costs, the potential benefits\u2014in knowledge, security, and inspiration\u2014suggest that humanity does indeed bear a responsibility to look beyond Earth and embrace the challenge of space.\n<\/p>\n\t\t<\/div>\n\t<\/div>\n\n<\/div>","DataExportTag":"Q5.1","QuestionID":"QID1219691452"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID1219691454","SecondaryAttribute":"With these essays in mind, you now turn to Brandon\u2019s essay: Brandon's essay The conflict between..","TertiaryAttribute":null,"Payload":{"QuestionText":"With these essays in mind, you now turn to <strong>Brandon\u2019s essay<\/strong>: \n<br><br>\n\n<div>\n\t <div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n    \n\t\t\n\t\t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t  Brandon's essay\n\t\t<\/div>\n\n\t\t\n\t\t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t  The conflict between convenience and sustainability\n\t\t<\/div>\n\n\t\t\n\t\t<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>In today\u2019s fast-paced world, convenience often dominates daily choices, yet it frequently clashes with sustainability. Modern lifestyles prioritize speed and ease\u2014single-use plastics, fast fashion, and on-demand delivery epitomize this trend. These conveniences save time and effort but come at a significant environmental cost, contributing to pollution, resource depletion, and climate change. For example, the popularity of disposable packaging reduces the burden on consumers but increases landfill waste, undermining long-term ecological balance.\n<\/p>\n\t\t\t<p>Sustainability, on the other hand, demands deliberate choices and often more effort: reusable products, energy-efficient practices, and mindful consumption require planning and patience. While these actions may seem inconvenient initially, they foster resilience and protect natural resources for future generations. The challenge lies in reconciling immediate comfort with long-term responsibility. Innovations such as eco-friendly packaging, renewable energy technologies, and sustainable urban design demonstrate that convenience and sustainability need not be mutually exclusive.\n<\/p>\n\t\t\t<p>Ultimately, achieving harmony between these priorities requires both systemic change and individual commitment. By rethinking habits, embracing responsible technologies, and valuing long-term ecological health over instant gratification, society can cultivate a lifestyle where convenience complements, rather than compromises, sustainability.\n<\/p>\n\t\t<\/div>\n\t<\/div><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"With these essays in mind, you now turn to Brandon\u2019s essay: Brandon's essay The conflict between...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"With these essays in mind, you now turn to <strong>Brandon\u2019s essay<\/strong>: \n<br><br>\n\n<div>\n\t <div style=\"margin-bottom: 20px; padding: 16px 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); background-color: #ffffff; border: 1px solid #e0e0e0;\">\n    \n\t\t\n\t\t<div style=\"font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 12px;\">\n\t\t  Brandon's essay\n\t\t<\/div>\n\n\t\t\n\t\t<div style=\"font-weight: bold; font-size: 15px; margin-bottom: 10px;\">\n\t\t  The conflict between convenience and sustainability\n\t\t<\/div>\n\n\t\t\n\t\t<div style=\"padding: 10px 14px; background-color: #f5f5f5; border-radius: 4px; font-size: 15px; line-height: 1.7;\">\n\t\t\t<p>In today\u2019s fast-paced world, convenience often dominates daily choices, yet it frequently clashes with sustainability. Modern lifestyles prioritize speed and ease\u2014single-use plastics, fast fashion, and on-demand delivery epitomize this trend. These conveniences save time and effort but come at a significant environmental cost, contributing to pollution, resource depletion, and climate change. For example, the popularity of disposable packaging reduces the burden on consumers but increases landfill waste, undermining long-term ecological balance.\n<\/p>\n\t\t\t<p>Sustainability, on the other hand, demands deliberate choices and often more effort: reusable products, energy-efficient practices, and mindful consumption require planning and patience. While these actions may seem inconvenient initially, they foster resilience and protect natural resources for future generations. The challenge lies in reconciling immediate comfort with long-term responsibility. Innovations such as eco-friendly packaging, renewable energy technologies, and sustainable urban design demonstrate that convenience and sustainability need not be mutually exclusive.\n<\/p>\n\t\t\t<p>Ultimately, achieving harmony between these priorities requires both systemic change and individual commitment. By rethinking habits, embracing responsible technologies, and valuing long-term ecological health over instant gratification, society can cultivate a lifestyle where convenience complements, rather than compromises, sustainability.\n<\/p>\n\t\t<\/div>\n\t<\/div><\/div>","DataExportTag":"Q5.2","QuestionID":"QID1219691454"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID1219691455","SecondaryAttribute":"You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely...","TertiaryAttribute":null,"Payload":{"QuestionText":"You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated.&nbsp;<br>The essay is displayed below sentence by sentence, each followed by an editable text box prefilled with that sentence. Edit as many sentences as you like using the following rules.&nbsp;<br>To <b>revise wording<\/b>, edit the sentence directly in its box. To <b>merge sentences<\/b>, write the full merged sentence in the text box of the first sentence's box; leave the following merged sentence box(es) empty. To <b>split a sentence<\/b>, write all resulting sentences in the box of the original sentence. To <b>delete a sentence<\/b>, leave its box empty.&nbsp;<br>Make all changes you find appropriate before proceeding with the survey.&nbsp;<br>","DefaultChoices":false,"QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"var qContainer;\nvar originalSentences; \/\/ global so addOnPageSubmit can access it\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    qContainer = this.getQuestionContainer(); \/\/ assign to global\n\t\n\tvar title = \"The conflict between convenience and sustainability\";\n    originalSentences = [\n        \"In today\u2019s fast-paced world, convenience often dominates daily choices, yet it frequently clashes with sustainability.\",\n        \"Modern lifestyles prioritize speed and ease\u2014single-use plastics, fast fashion, and on-demand delivery epitomize this trend.\",\n        \"These conveniences save time and effort but come at a significant environmental cost, contributing to pollution, resource depletion, and climate change.\",\n\t\t\"For example, the popularity of disposable packaging reduces the burden on consumers but increases landfill waste, undermining long-term ecological balance.\",\n\t\t\"Sustainability, on the other hand, demands deliberate choices and often more effort: reusable products, energy-efficient practices, and mindful consumption require planning and patience.\",\n\t\t\"While these actions may seem inconvenient initially, they foster resilience and protect natural resources for future generations.\",\n\t\t\"The challenge lies in reconciling immediate comfort with long-term responsibility.\",\n\t\t\"Innovations such as eco-friendly packaging, renewable energy technologies, and sustainable urban design demonstrate that convenience and sustainability need not be mutually exclusive.\",\n\t\t\"Ultimately, achieving harmony between these priorities requires both systemic change and individual commitment.\",\n\t\t\"By rethinking habits, embracing responsible technologies, and valuing long-term ecological health over instant gratification, society can cultivate a lifestyle where convenience complements, rather than compromises, sustainability.\"\n    ];\n\n    \/\/ hide default Qualtrics input\n    var defaultInput = qContainer.querySelector(\"textarea\");\n    defaultInput.style.display = \"none\";\n\t\n\t\/\/ create container for custom sentence boxes\n    var textEntryContainer = document.createElement(\"div\");\n    defaultInput.parentNode.appendChild(textEntryContainer);\n\t\n\t\/\/ display title\n\tvar titleEl = document.createElement(\"h3\");\n\ttitleEl.textContent = title;\n\ttitleEl.style.marginBottom = \"15px\";\n\ttextEntryContainer.appendChild(titleEl);\n    \n    \/\/ render one editable box per sentence\n    originalSentences.forEach(function(sentence, idx) {\n\t\tvar wrapper = document.createElement(\"div\");\n\t\twrapper.style.marginBottom = \"20px\";\n\t\twrapper.style.padding = \"16px 20px\";\n\t\twrapper.style.borderRadius = \"8px\";\n\t\twrapper.style.boxShadow = \"0 2px 6px rgba(0,0,0,0.12)\";\n\t\twrapper.style.backgroundColor = \"#ffffff\";\n\t\twrapper.style.border = \"1px solid #e0e0e0\";\n\n\t\t\/\/ sentence number header\n\t\tvar header = document.createElement(\"div\");\n\t\theader.style.fontWeight = \"600\";\n\t\theader.style.fontSize = \"13px\";\n\t\theader.style.textTransform = \"uppercase\";\n\t\theader.style.letterSpacing = \"0.05em\";\n\t\theader.style.color = \"#888\";\n\t\theader.style.marginBottom = \"12px\";\n\t\theader.textContent = \"Sentence \" + (idx + 1);\n\t\twrapper.appendChild(header);\n\n\t\t\/\/ original sentence \u2014 grey pill background (non-editable display)\n\t\tvar origDiv = document.createElement(\"div\");\n\t\torigDiv.style.marginBottom = \"10px\";\n\t\torigDiv.style.padding = \"8px 12px\";\n\t\torigDiv.style.backgroundColor = \"#f5f5f5\";\n\t\torigDiv.style.borderRadius = \"4px\";\n\t\torigDiv.style.fontSize = \"15px\";\n\t\torigDiv.style.lineHeight = \"1.5\";\n\t\tvar origLabel = document.createElement(\"div\");\n\t\torigLabel.style.fontSize = \"11px\";\n\t\torigLabel.style.fontWeight = \"600\";\n\t\torigLabel.style.textTransform = \"uppercase\";\n\t\torigLabel.style.color = \"#aaa\";\n\t\torigLabel.style.marginBottom = \"4px\";\n\t\torigLabel.textContent = \"Original\";\n\t\torigDiv.appendChild(origLabel);\n\t\torigDiv.appendChild(document.createTextNode(sentence));\n\t\twrapper.appendChild(origDiv);\n\n\t\t\/\/ editable textarea label\n\t\tvar editLabel = document.createElement(\"div\");\n\t\teditLabel.style.fontSize = \"11px\";\n\t\teditLabel.style.fontWeight = \"600\";\n\t\teditLabel.style.textTransform = \"uppercase\";\n\t\teditLabel.style.color = \"#5b9bd5\";\n\t\teditLabel.style.marginBottom = \"6px\";\n\t\teditLabel.textContent = \"Your edit\";\n\t\twrapper.appendChild(editLabel);\n\n\t\t\/\/ editable textarea\n\t\tvar textarea = document.createElement(\"textarea\");\n\t\ttextarea.value = sentence;\n\t\ttextarea.rows = 2;\n\t\ttextarea.style.width = \"100%\";\n\t\ttextarea.style.boxSizing = \"border-box\";\n\t\ttextarea.style.padding = \"8px 10px\";\n\t\ttextarea.style.border = \"1px solid #ddd\";\n\t\ttextarea.style.borderRadius = \"4px\";\n\t\ttextarea.style.fontSize = \"14px\";\n\t\ttextarea.style.resize = \"vertical\";\n\t\ttextarea.style.fontFamily = \"inherit\";\n\t\ttextarea.style.backgroundColor = \"#f0f6ff\";\n\t\ttextarea.className = \"sentenceBox\";\n\t\ttextarea.dataset.index = idx;\n\t\twrapper.appendChild(textarea);\n\n\t\ttextEntryContainer.appendChild(wrapper);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnPageSubmit(function() {\n    var resultPairs = [];\n\n    qContainer.querySelectorAll(\".sentenceBox\").forEach(function(box) {\n        var orig = originalSentences[parseInt(box.dataset.index, 10)]; \n        var edited = box.value.trim();\n        resultPairs.push({ orig: orig, edited: edited });\n    });\n\n    var json = JSON.stringify(resultPairs);\n\tconsole.log(\"Saving EditPairsJSON:\", json);\n\tQualtrics.SurveyEngine.setEmbeddedData(\"EditPairsJSON\", btoa(unescape(encodeURIComponent(json))));\n});","QuestionText_Unsafe":"You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated.&nbsp;<br>The essay is displayed below sentence by sentence, each followed by an editable text box prefilled with that sentence. Edit as many sentences as you like using the following rules.&nbsp;<br>To <b>revise wording<\/b>, edit the sentence directly in its box. To <b>merge sentences<\/b>, write the full merged sentence in the text box of the first sentence's box; leave the following merged sentence box(es) empty. To <b>split a sentence<\/b>, write all resulting sentences in the box of the original sentence. To <b>delete a sentence<\/b>, leave its box empty.&nbsp;<br>Make all changes you find appropriate before proceeding with the survey.&nbsp;<br>","DataExportTag":"Q5.3","QuestionID":"QID1219691455"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID1219691456","SecondaryAttribute":"Below you can find each original sentence alongside your edited version. Explain each change you...","TertiaryAttribute":null,"Payload":{"QuestionText":"Below you can find each original sentence alongside your edited version. Explain&nbsp;each change you made in the box below each pair.","DefaultChoices":false,"QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Below you can find each original sentence alongside your edited version. Explain each change you...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"var qContainer;\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    qContainer = this.getQuestionContainer();\n\n    var raw = \"${e:\/\/Field\/EditPairsJSON}\";\n\n    if (!raw) {\n        console.log(\"EditPairsJSON is empty\");\n        return;\n    }\n\n    var pairs;\n    try {\n        var json = decodeURIComponent(escape(atob(raw)));\n        pairs = JSON.parse(json);\n    } catch(e) {\n        console.log(\"Decode\/parse failed:\", e, \"| Raw:\", raw);\n        return;\n    }\n\n    \/\/ hide default Qualtrics input\n    var defaultInput = qContainer.querySelector(\"textarea\");\n    defaultInput.style.display = \"none\";\n\n    \/\/ create main container\n    var container = document.createElement(\"div\");\n    defaultInput.parentNode.appendChild(container);\n\n    \/\/ word-level diff helper\n    function wordDiff(orig, edited) {\n        var origWords = orig.split(\" \");\n        var editedWords = edited.split(\" \");\n        var result = document.createDocumentFragment();\n\n        var m = origWords.length, n = editedWords.length;\n        var dp = [];\n        for (var i = 0; i <= m; i++) {\n            dp[i] = [];\n            for (var j = 0; j <= n; j++) dp[i][j] = 0;\n        }\n        for (var i = 1; i <= m; i++)\n            for (var j = 1; j <= n; j++)\n                dp[i][j] = origWords[i-1] === editedWords[j-1]\n                    ? dp[i-1][j-1] + 1\n                    : Math.max(dp[i-1][j], dp[i][j-1]);\n\n        var ops = [], i = m, j = n;\n        while (i > 0 || j > 0) {\n            if (i > 0 && j > 0 && origWords[i-1] === editedWords[j-1]) {\n                ops.unshift({ type: \"keep\", word: editedWords[j-1] });\n                i--; j--;\n            } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {\n                ops.unshift({ type: \"add\", word: editedWords[j-1] });\n                j--;\n            } else {\n                ops.unshift({ type: \"remove\", word: origWords[i-1] });\n                i--;\n            }\n        }\n\n        ops.forEach(function(op, k) {\n            var span = document.createElement(\"span\");\n            span.textContent = (k > 0 ? \" \" : \"\") + op.word;\n            if (op.type === \"add\") {\n                span.style.backgroundColor = \"#c6efce\";\n                span.style.borderRadius = \"3px\";\n                span.style.padding = \"0 2px\";\n            } else if (op.type === \"remove\") {\n                span.style.backgroundColor = \"#ffc7ce\";\n                span.style.textDecoration = \"line-through\";\n                span.style.borderRadius = \"3px\";\n                span.style.padding = \"0 2px\";\n                span.style.color = \"#888\";\n            }\n            result.appendChild(span);\n        });\n\n        return result;\n    }\n\n    \/\/ render one block per sentence pair\n    pairs.forEach(function(pair, idx) {\n        var isModified = pair.orig !== pair.edited;\n\n        var wrapper = document.createElement(\"div\");\n        wrapper.style.marginBottom = \"20px\";\n        wrapper.style.padding = \"16px 20px\";\n        wrapper.style.borderRadius = \"8px\";\n        wrapper.style.boxShadow = \"0 2px 6px rgba(0,0,0,0.12)\";\n        wrapper.style.backgroundColor = \"#ffffff\";\n        wrapper.style.border = \"1px solid #e0e0e0\";\n\n        \/\/ header\n        var header = document.createElement(\"div\");\n        header.style.fontWeight = \"600\";\n        header.style.fontSize = \"13px\";\n        header.style.textTransform = \"uppercase\";\n        header.style.letterSpacing = \"0.05em\";\n        header.style.color = \"#888\";\n        header.style.marginBottom = \"12px\";\n        header.textContent = \"Sentence \" + (idx + 1);\n        wrapper.appendChild(header);\n\n        \/\/ original sentence\n        var origDiv = document.createElement(\"div\");\n        origDiv.style.marginBottom = \"8px\";\n        origDiv.style.padding = \"8px 12px\";\n        origDiv.style.backgroundColor = \"#f5f5f5\";\n        origDiv.style.borderRadius = \"4px\";\n        origDiv.style.fontSize = \"15px\";\n        origDiv.style.lineHeight = \"1.5\";\n        var origStrong = document.createElement(\"div\");\n        origStrong.style.fontSize = \"11px\";\n        origStrong.style.fontWeight = \"600\";\n        origStrong.style.textTransform = \"uppercase\";\n        origStrong.style.color = \"#aaa\";\n        origStrong.style.marginBottom = \"4px\";\n        origStrong.textContent = \"Original\";\n        origDiv.appendChild(origStrong);\n        origDiv.appendChild(document.createTextNode(pair.orig));\n        wrapper.appendChild(origDiv);\n\n        \/\/ edited sentence\n        var editedDiv = document.createElement(\"div\");\n        editedDiv.style.marginBottom = \"14px\";\n        editedDiv.style.padding = \"8px 12px\";\n        editedDiv.style.backgroundColor = isModified ? \"#f0fff4\" : \"#f5f5f5\";\n        editedDiv.style.borderRadius = \"4px\";\n        editedDiv.style.fontSize = \"15px\";\n        editedDiv.style.lineHeight = \"1.5\";\n        var editedStrong = document.createElement(\"div\");\n        editedStrong.style.fontSize = \"11px\";\n        editedStrong.style.fontWeight = \"600\";\n        editedStrong.style.textTransform = \"uppercase\";\n        editedStrong.style.color = isModified ? \"#4caf7d\" : \"#aaa\";\n        editedStrong.style.marginBottom = \"4px\";\n        editedStrong.textContent = isModified ? \"Your edit\" : \"Unchanged\";\n        editedDiv.appendChild(editedStrong);\n        editedDiv.appendChild(wordDiff(pair.orig, pair.edited));\n      \n        wrapper.appendChild(editedDiv);\n\n        \/\/ explanation label + box only if modified\n        if (isModified) {\n            var label = document.createElement(\"div\");\n            label.style.fontSize = \"13px\";\n            label.style.fontWeight = \"600\";\n            label.style.marginBottom = \"6px\";\n            label.style.color = \"#555\";\n            label.textContent = \"Why did you make this change?\";\n            wrapper.appendChild(label);\n\n            var explanationBox = document.createElement(\"textarea\");\n            explanationBox.rows = 3;\n            explanationBox.style.width = \"100%\";\n            explanationBox.style.boxSizing = \"border-box\";\n            explanationBox.style.padding = \"8px 10px\";\n            explanationBox.style.border = \"1px solid #ddd\";\n            explanationBox.style.borderRadius = \"4px\";\n            explanationBox.style.fontSize = \"14px\";\n            explanationBox.style.resize = \"vertical\";\n            explanationBox.style.fontFamily = \"inherit\";\n            explanationBox.className = \"explanationBox\";\n            explanationBox.dataset.index = idx;\n            wrapper.appendChild(explanationBox);\n        }\n\n        container.appendChild(wrapper);\n    });\n});\n\n\nQualtrics.SurveyEngine.addOnPageSubmit(function() {\n    var explanations = [];\n\n    qContainer.querySelectorAll(\".explanationBox\").forEach(function(box) {\n        explanations.push({\n            index: parseInt(box.dataset.index, 10), \/\/ which sentence pair this belongs to\n            explanation: box.value.trim()\n        });\n    });\n\n    Qualtrics.SurveyEngine.setEmbeddedData(\"EditExplanationsJSON\", JSON.stringify(explanations));\n});","QuestionText_Unsafe":"Below you can find each original sentence alongside your edited version. Explain&nbsp;each change you made in the box below each pair.","DataExportTag":"Q5.4","QuestionID":"QID1219691456"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID14","SecondaryAttribute":"Does your text read more convincingly human than the original?\u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"Does your text read more convincingly human than the original?&nbsp;<br>","DefaultChoices":false,"DataExportTag":"stop_crit","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Does your text read more convincingly human than the original?\u00a0","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID14","QuestionText_Unsafe":"Does your text read more convincingly human than the original?&nbsp;<br>"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Which of the following best represents your view on the impact that LLM chatbots (will) have on s...","TertiaryAttribute":null,"Payload":{"QuestionText":"Which of the following best represents your view on the impact that LLM chatbots (will) have on society?","DataExportTag":"LLM_impact","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which of the following best represents your view on the impact that LLM chatbots (will) have on s...","Choices":{"1":{"Display":"LLM chatbots will be very detrimental to society"},"2":{"Display":"LLM chatbots will have more negative than positive effects on society"},"3":{"Display":"LLM chatbots won't have any impact on society"},"4":{"Display":"LLM chatbots will have more positive than negative effects on society"},"5":{"Display":"LLM chatbots will be very beneficial to society"},"6":{"Display":"I have no opinion on the impact of LLM chatbots on society"}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID21","QuestionText_Unsafe":"Which of the following best represents your view on the impact that LLM chatbots (will) have on society?","ChoiceGroups":{"cg_1":{"ChoiceGroupOrder":[6],"GroupLabel":"_____________________","Options":{"Selection":"SAWithinQuestion"}}},"ChoiceGroupOrder":[1,2,3,4,5,"cg_1"]}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"Has your writing style changed since you started using, or became aware of, LLM chatbots?","TertiaryAttribute":null,"Payload":{"QuestionText":"Has your writing style changed since you started using, or became aware of, LLM chatbots?","DataExportTag":"writing_style_pre","QuestionType":"MC","Selector":"SAHR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Has your writing style changed since you started using, or became aware of, LLM chatbots?","Choices":{"1":{"Display":"Not at all"},"2":{"Display":"Somewhat"},"3":{"Display":"A lot"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID22","SubSelector":"TX","QuestionText_Unsafe":"Has your writing style changed since you started using, or became aware of, LLM chatbots?"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Do you think your writing style will change as a result of this experiment?","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you think your writing style will change as a result of this experiment?","DataExportTag":"writing_style_post","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you think your writing style will change as a result of this experiment?","Choices":{"1":{"Display":"Yes (explain):","TextEntry":"true"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CustomValidation","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID23\/SelectableChoice\/2","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Do you think your writing style will change as a result of this experiment?<\/span> <span class=\"LeftOpDesc\">No<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID23\/SelectableChoice\/2","LogicType":"Question","Operator":"Selected","QuestionID":"QID23","QuestionIDFromLocator":"QID23","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q:\/\/QID23\/ChoiceTextEntryValue\/1","Conjuction":"Or","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Do you think your writing style will change as a result of this experiment?<\/span> <span class=\"LeftOpDesc\">Text Response<\/span> <span class=\"OpDesc\">Is Not Empty<\/span> ","LeftOperand":"q:\/\/QID23\/ChoiceTextEntryValue\/1","LogicType":"Question","Operator":"NotEmpty","QuestionID":"QID23","QuestionIDFromLocator":"QID23","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression"},"Message":{"description":"Require entry in text box","libraryID":null,"messageID":null,"subMessageID":"VE_FORCE_RESPONSE_OTHER"}}}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID23","QuestionText_Unsafe":"Do you think your writing style will change as a result of this experiment?"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Dear participant, You will be taking part in the Machine speech, human speech project conducted b...","TertiaryAttribute":null,"Payload":{"QuestionText":"Dear participant,<br>\n<br>\nYou will be taking part in the <i>Machine speech, human speech<\/i> project conducted by Raya Mezeklieva under the supervision of Fausto Carcassi and Giorgio Sbardolini from the Institute of Logic, Language and Computation (ILLC) of the University of Amsterdam.<br>\n<br>\n<b>Purpose of the research project <\/b><br>\nLarge language models (LLMs) can generate text that is almost indistinguishable from human writing. Given the increasing popularity and availability of these systems, people\u2019s skepticism towards the authenticity of written content intensifies. This research aims to find out how people may modify written text to signal human authorship and distinguish it from LLM-generated content.&nbsp;<br>\n<br>\n<b>Who can take part in this research? <\/b><br>\nWe are inviting adult native speakers of the English language to take part in this research.&nbsp;Before the experiment begins, we will verify you match this profile.<br>\n<br>\n<b>Instructions and procedure <\/b><br>\nThe experiment will start with a few questions regarding your background and your experience with LLMs (~3 minutes). During the main task, you will read two texts, then you will edit a third text with the goal of distinguishing its writing style from the texts you will have just read. Each text will contain approximately 200 words. After you have submitted your modifications, you will be asked to explain your reasoning. At the end of the experiment, you will be debriefed about your experience and the purpose of this study (~3 minutes). The total duration of the experiment will be approximately 20 minutes.\n\n<br>\nYou are not allowed to use any generative artificial intelligence tools or external assistance during any part of the experiment. This includes, but is not limited to, text-generating systems, automated writing tools, or paraphrasing software.<br>\n<br>\n<b>Voluntary participation &amp; risks <\/b><br>\nYou will be participating in this research on a voluntary basis. This means you are free to stop taking part at any stage without consequences or penalty. If you decide to stop or withdraw your consent, all the information gathered up until then will be permanently deleted. This research has no known risks.<br>\n<br>\n<b>Privacy <\/b><br>\nThe information gathered will be used for the master\u2019s thesis of Raya Mezeklieva, which will be published on the <a href=\"https:\/\/msclogic.illc.uva.nl\/theses\/recent\/\">ILLC website<\/a>. Any other potential publication for which the data could be used will be in scientific journals only. Fully anonymized data may be available online in tandem with these scientific publications. We guarantee that you will remain anonymous under all circumstances. Your personal information will not be viewed by third parties. Participants can request more information from the researcher at any time about their rights as data subjects under the EU privacy law, the GDPR.<br>\n<br>\n<b>Further Information<\/b><br>\nFor further information, please contact Raya Mezeklieva (<a href=\"mailto:raya.mezeklieva@student.uva.nl\">raya.mezeklieva@student.uva.nl<\/a>), Fausto Carcassi (<a href=\"mailto:f.carcassi@uva.nl\">f.carcassi@uva.nl<\/a>), or Giorgio Sbardolini (<a href=\"mailto:g.sbardolini@uva.nl\">g.sbardolini@uva.nl<\/a>). If you have any complaints regarding this project, you can contact the Secretary of the Ethics Committee of the Faculty of Humanities of the University of Amsterdam (<a href=\"mailto:commissie-ethiek-fgw@uva.nl\">commissie-ethiek-fgw@uva.nl<\/a>).","DefaultChoices":false,"DataExportTag":"consent_info","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dear participant, You will be taking part in the Machine speech, human speech project conducted b...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID24","QuestionText_Unsafe":"Dear participant,<br \/>\n<br \/>\nYou will be taking part in the <i>Machine speech, human speech<\/i> project conducted by Raya Mezeklieva under the supervision of Fausto Carcassi and Giorgio Sbardolini from the Institute of Logic, Language and Computation (ILLC) of the University of Amsterdam.<br \/>\n<br \/>\n<b>Purpose of the research project <\/b><br \/>\nLarge language models (LLMs) can generate text that is almost indistinguishable from human writing. Given the increasing popularity and availability of these systems, people&rsquo;s skepticism towards the authenticity of written content intensifies. This research aims to find out how people may modify written text to signal human authorship and distinguish it from LLM-generated content.&nbsp;<br \/>\n<br \/>\n<b>Who can take part in this research? <\/b><br \/>\nWe are inviting adult native speakers of the English language to take part in this research.&nbsp;Before the experiment begins, we will verify you match this profile.<br \/>\n<br \/>\n<b>Instructions and procedure <\/b><br \/>\nThe experiment will start with a few questions regarding your background and your experience with LLMs. During the main task, you will read three texts, then you will edit a fourth text with the goal of distinguishing its writing style from the texts you will have just read. Each text will contain approximately 200 words. After you have submitted your modifications, you will be asked to explain your reasoning. At the end of the experiment, you will be debriefed about your experience and the purpose of this study. The total duration of the experiment will be 20-30 minutes.<br \/>\n<br \/>\nYou are not allowed to use any generative artificial intelligence tools or external assistance during any part of the experiment. This includes, but is not limited to, text-generating systems, automated writing tools, or paraphrasing software.<br \/>\n<br \/>\n<b>Voluntary participation &amp; risks <\/b><br \/>\nYou will be participating in this research on a voluntary basis. This means you are free to stop taking part at any stage without consequences or penalty. If you decide to stop or withdraw your consent, all the information gathered up until then will be permanently deleted. This research has no known risks.<br \/>\n<br \/>\n<b>Privacy <\/b><br \/>\nThe information gathered will be used for the master&rsquo;s thesis of Raya Mezeklieva, which will be published on the <a href=\"https:\/\/msclogic.illc.uva.nl\/theses\/recent\/\">ILLC website<\/a>. Any other potential publication for which the data could be used will be in scientific journals only. Fully anonymized data may be available online in tandem with these scientific publications. We guarantee that you will remain anonymous under all circumstances. Your personal information will not be viewed by third parties. Participants can request more information from the researcher at any time about their rights as data subjects under the EU privacy law, the GDPR.<br \/>\n<br \/>\n<b>Further Information<\/b><br \/>\nFor further information, please contact Raya Mezeklieva (<a href=\"mailto:raya.mezeklieva@student.uva.nl\">raya.mezeklieva@student.uva.nl<\/a>), Fausto Carcassi (<a href=\"mailto:f.carcassi@uva.nl\">f.carcassi@uva.nl<\/a>), or Giorgio Sbardolini (<a href=\"mailto:g.sbardolini@uva.nl\">g.sbardolini@uva.nl<\/a>). If you have any complaints regarding this project, you can contact the Secretary of the Ethics Committee of the Faculty of Humanities of the University of Amsterdam (<a href=\"mailto:commissie-ethiek-fgw@uva.nl\">commissie-ethiek-fgw@uva.nl<\/a>)."}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"I consent to not using any generative artificial intelligence tools or external assistance during...","TertiaryAttribute":null,"Payload":{"QuestionText":"I consent to not using any generative artificial intelligence tools or external assistance during any part of the experiment. This includes, but is not limited to, text-generating systems, automated writing tools, or paraphrasing software.","DefaultChoices":false,"DataExportTag":"consent_genAI","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I consent to not using any generative artificial intelligence tools or external assistance during...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID28","QuestionText_Unsafe":"I consent to not using any generative artificial intelligence tools or external assistance during any part of the experiment. This includes, but is not limited to, text-generating systems, automated writing tools, or paraphrasing software."}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"If you have any remarks, you can share them here.","TertiaryAttribute":null,"Payload":{"QuestionText":"If you have any remarks, you can share them here.","DefaultChoices":false,"DataExportTag":"remarks","QuestionID":"QID29","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you have any remarks, you can share them here.","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"If you have any remarks, you can share them here."}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"To show you are paying attention, please select \"Strongly disagree\".","TertiaryAttribute":null,"Payload":{"QuestionText":"To show you are paying attention, please select \"Strongly disagree\".","DataExportTag":"att1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"To show you are paying attention, please select \"Strongly disagree\".","Choices":{"1":{"Display":"Strongly agree"},"2":{"Display":"Somewhat agree"},"3":{"Display":"Somewhat disagree"},"4":{"Display":"Strongly disagree"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID30","QuestionText_Unsafe":"To show you are paying attention, please select \"Strongly disagree\"."}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"Do you agree with the following statement: \"I am 3 meters (10 feet) tall.\"","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you agree with the following statement: \"I am 3 meters (10 feet) tall.\"<br>","DataExportTag":"att2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you agree with the following statement: \"I am 3 meters (10 feet) tall.\"","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID31","QuestionText_Unsafe":"Do you agree with the following statement: \"I am 3 meters (10 feet) tall.\"<br>"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID35","SecondaryAttribute":"Informed consent I have been clearly informed about the research project and I consent to partici...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Informed consent <\/b><br>I have been clearly informed about the research project and I consent to participate in this research. I retain the right to revoke this consent without having to provide any reasons for my decision. I am aware that I am entitled to discontinue the research at any time and can withdraw my participation.","DataExportTag":"consent","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Informed consent I have been clearly informed about the research project and I consent to partici...","Choices":{"1":{"Display":"I consent to participate in this research."},"3":{"Display":"I do not consent."}},"ChoiceOrder":["1","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CustomValidation","MinChoices":"1","MaxChoices":"1","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID35\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Informed consent I have been clearly informed about the research project and I consent to partici...<\/span> <span class=\"LeftOpDesc\">I consent to participate in this research.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID35\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID35","QuestionIDFromLocator":"QID35","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q:\/\/QID35\/SelectableChoice\/1","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Informed consent I have been clearly informed about the research project and I consent to partici...<\/span> <span class=\"LeftOpDesc\">I consent to participate in this research.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID35\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID35","QuestionIDFromLocator":"QID35","QuestionIsInLoop":"no","Type":"Expression"},"2":{"ChoiceLocator":"q:\/\/QID35\/SelectableChoice\/3","Conjuction":"Or","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Informed consent I have been clearly informed about the research project and I consent to partici...<\/span> <span class=\"LeftOpDesc\">I do not consent.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID35\/SelectableChoice\/3","LogicType":"Question","Operator":"Selected","QuestionID":"QID35","QuestionIDFromLocator":"QID35","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression"},"Message":{"description":"Require multiple responses","libraryID":null,"messageID":null,"subMessageID":"VE_FORCE_RESPONSE_PLURAL"}}}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID35","QuestionText_Unsafe":"<b>Informed consent <\/b><br>I have been clearly informed about the research project and I consent to participate in this research. I retain the right to revoke this consent without having to provide any reasons for my decision. I am aware that I am entitled to discontinue the research at any time and can withdraw my participation."}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"Thank you for taking part in this experiment! Note that some of the information you were given du...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for taking part in this experiment!<br>\nNote that some of the information you were given during the task might have been misleading. Please read the following carefully to understand what and why.<br>\n<br>\nThis study uses an iterative design: you were part of one of several chains of participants. The first participant in each chain received a text generated by an LLM (GPT 5.2). Each subsequent participant received the version of the text that had been edited by the previous participant. Although you were told that the text was LLM-generated, this might not have been the case depending on your position in the chain. This was necessary for the purpose of the study, namely to identify the linguistic strategies people use to make a text appear human-authored in a context where LLMs are becoming increasingly capable of producing human-like writing. Misleading you about the origin of the text you received was necessary to simulate this context.&nbsp;<br>\n<br>\nIf you have any questions about the study, its purpose, or the design, please feel free to contact the research team. If you feel uncomfortable about the use of deception, you may withdraw your data without penalty by contacting&nbsp;Raya Mezeklieva (<a href=\"mailto:raya.mezeklieva@student.uva.nl\">raya.mezeklieva@student.uva.nl<\/a>).<br><br>Please click the button below to be redirected back to Prolific and register your submission.&nbsp;<br>","DefaultChoices":false,"DataExportTag":"debrief","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for taking part in this experiment! Note that some of the information you were given du...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID38","QuestionText_Unsafe":"Thank you for taking part in this experiment!<br>\nNote that some of the information you were given during the task might not have been misleading. Please read the following carefully to understand what and why.<br>\n<br>\nThis study uses an iterative design: you were part of one of several chains of participants. The first participant in each chain received a text generated by an LLM (GPT 5.2). Each subsequent participant received the version of the text that had been edited by the previous participant. Although you were told that the text was LLM-generated, this might not have been the case depending on your position in the chain. This was necessary for the purpose of the study, namely to identify the linguistic strategies people use to make a text appear human-authored in a context where LLMs are becoming increasingly capable of producing human-like writing. Thus, misleading you about the origin of the text you received was necessary to simulate this context.&nbsp;<br>\n<br>\nIf you have any questions about the study, its purpose, or the design, please feel free to contact the research team. If you feel uncomfortable about the use of deception, you may withdraw your data without penalty by contacting us.<br>\nRaya Mezeklieva: <a href=\"mailto:raya.mezeklieva@student.uva.nl\">raya.mezeklieva@student.uva.nl<\/a><br>\nFausto Carcassi: <a href=\"mailto:f.carcassi@uva.nl\">f.carcassi@uva.nl<\/a><br>\nGiorgio Sbardolini: <a href=\"mailto:g.sbardolini@uva.nl\">g.sbardolini@uva.nl<\/a>"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"Did you use any LLM chatbots to (help you) complete the task?","TertiaryAttribute":null,"Payload":{"QuestionText":"Did you use any LLM chatbots to (help you) complete the task?","DefaultChoices":false,"DataExportTag":"if_genAI_used","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Did you use any LLM chatbots to (help you) complete the task?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID4","QuestionText_Unsafe":"Did you use any LLM chatbots to (help you) complete the task?"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Brandon's text is shown again sentence by sentence, each followed by an editable text box prefill...","TertiaryAttribute":null,"Payload":{"QuestionText":"Brandon's text is shown again sentence by sentence, each followed by an\neditable text box prefilled with that sentence.\nMake any changes you think will help the text read convincingly as\nhuman-written and unlikely to be identified as LLM-generated. You may rephrase,\nadd, or remove content as you see fit. If you choose to merge sentences, enter\nthe combined version in the first relevant text box and leave the following\none(s) empty. You can also split sentences by writing multiple sentences within\na single text box. Edit as many text boxes as you feel are needed.\n<br \/><br \/>","DefaultChoices":false,"DataExportTag":"edit_c0","QuestionID":"QID50","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Brandon's text is shown again sentence by sentence, each followed by an editable text box prefill...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"var qContainer\nvar originalSentences\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    qContainer = this.getQuestionContainer()\n\n    var title = \"__STIMULUS_TITLE__\"\n    originalSentences = __SENTENCE_LIST__\n\n    \/\/ hide default text input box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    \/\/ create div element for new container to be filled with sentence editing blocks\n    var textEntryContainer = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(textEntryContainer)\n\n    \/\/ create container title element\n    var titleWrapper = document.createElement(\"div\")\n    titleWrapper.className = \"card\"\n    titleWrapper.style.backgroundColor = \"#fafafa\" \/\/ slightly different to distinguish from sentences\n\n    var titleLabel = document.createElement(\"div\")\n    titleLabel.className = \"card-label\"\n    titleLabel.textContent = \"Title\"\n    titleWrapper.appendChild(titleLabel)\n\n    var titleEl = document.createElement(\"div\")\n    titleEl.className = \"stimulus-title\"\n    titleEl.textContent = title\n    titleWrapper.appendChild(titleEl)\n\n    textEntryContainer.appendChild(titleWrapper)\n\n    \/\/ create individual sentence elements\n    originalSentences.forEach(function (sentence, idx) {\n        \/\/ wrapper (the full card)\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        \/\/ card header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        \/\/ original sentence display\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n\n        \/\/ create a separate container for the actual text to apply styles\n        var origText = document.createElement(\"div\")\n        origText.textContent = sentence\n\n        \/\/ original sentence label\n        var origLabel = document.createElement(\"div\")\n        origLabel.className =\n            \"sentence_type-label sentence_type-label--orig\"\n        origLabel.textContent = \"Original\"\n\n        origDiv.appendChild(origLabel)\n        origDiv.appendChild(origText) \/\/ append text as a div to ensure styling\n        wrapper.appendChild(origDiv)\n\n        \/\/ edit label\n        var editLabel = document.createElement(\"div\")\n        editLabel.className = \"sentence_type-label sentence_type-label--edit\"\n        editLabel.textContent = \"Your edit\"\n        wrapper.appendChild(editLabel)\n\n        \/\/ text area for user edit\n        var textarea = document.createElement(\"textarea\")\n        textarea.value = sentence \/\/ prefilled with original sentence\n        textarea.className = \"sentenceBox edit-textarea\"\n        textarea.dataset.index = idx\n        wrapper.appendChild(textarea)\n\n        textEntryContainer.appendChild(wrapper)\n\n        \/\/ adjust height to fit the prefilled content\n        textarea.style.height = \"auto\"\n        textarea.style.height = textarea.scrollHeight + \"px\"\n    })\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    \/\/ save original:edited sentence pairs\n    var resultPairs = []\n\n    qContainer.querySelectorAll(\".sentenceBox\").forEach(function (box) {\n        \/\/ trim both to avoid whitespace issues (user asked to explain a white space removal they didn't make)\n        var orig = originalSentences[parseInt(box.dataset.index, 10)].trim()\n        var edited = box.value.trim()\n        resultPairs.push({ orig: orig, edited: edited })\n    })\n\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditPairsJSON\", \n        \/\/ JSON.stringify(resultPairs)\n        btoa(unescape(encodeURIComponent(JSON.stringify(resultPairs)))), \/\/ base64 encoding (safer storage)\n    )\n})","QuestionText_Unsafe":"You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated.\n<br><br>\nThe essay is displayed below sentence by sentence, each followed by an editable text box, which is prefilled with that sentence. Edit as many sentences as you like using the following rules:\n<ul> \n\t<li>To <b>revise wording<\/b>, edit the sentence directly in its box.<\/li>\n\t<li>To <b>merge sentences<\/b>, write the full merged sentence in the text box of the first sentence's box; leave the following merged sentence box(es) empty.<\/li> \n\t<li>To <b>split a sentence<\/b>, write all resulting sentences in the box of the original sentence.<\/li> \n\t<li>To <b>delete a sentence<\/b>, leave its box empty.<\/li>\n<\/ul>\nMake all changes you find appropriate before proceeding with the survey.<br><br>"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID53","SecondaryAttribute":"Below you can find each original sentence alongside your edited version. Explain each change you...","TertiaryAttribute":null,"Payload":{"QuestionText":"Below you can find each original sentence alongside your edited version. \n<b>Explain<\/b> each change you made in the box below each pair.","DefaultChoices":false,"DataExportTag":"explain_c0","QuestionID":"QID53","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Below you can find each original sentence alongside your edited version. Explain each change you...","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None","MinChars":"1"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"\/\/ ----------\n\/\/ HELPER FUNCS\n\/\/ ----------\n\n\/\/ --- word-level diffs helper ---\nfunction wordDiff(orig, edited) {\n    \/\/ tokenize: split into words; punctuation treated as separate tokens\n    function tokenize(str) {\n        return str.match(\/[a-zA-Z0-9']+|[^a-zA-Z0-9'\\s]\/g) || []\n    }\n\n    var origWords = tokenize(orig)\n    var editedWords = tokenize(edited)\n    var result = document.createDocumentFragment() \/\/ build diffs display in a fragment to be inserted into the DOM at once\n    \/\/ fragment is iteratively built from <span> elements\n\n    var m = origWords.length,\n        n = editedWords.length\n    var dp = [] \/\/ dynamic programming table\n\n    \/\/ initialize dp table\n    for (var i = 0; i <= m; i++) {\n        dp[i] = []\n        for (var j = 0; j <= n; j++) dp[i][j] = 0\n    }\n\n    \/\/ compute longest common subsequence length\n    \/\/ iterate over original (i) and edited (j) sentences, word by word\n    for (var i = 1; i <= m; i++)\n        for (var j = 1; j <= n; j++)\n            \/\/ fill dp table\n            dp[i][j] =\n                \/\/ note: dp[1][1] corresp to origWords[0] vs editedWords[0] => hence -1 offset\n                origWords[i - 1] === editedWords[j - 1] \/\/ test match\n                    ? dp[i - 1][j - 1] + 1 \/\/ if match => extend LCS count by 1\n                    : Math.max(dp[i - 1][j], dp[i][j - 1]) \/\/ if no match => take max achievable LCS by removing from orig or edited\n\n    \/\/ backtrack to find and store edit operations (keep\/add\/remove)\n    var ops = [],\n        \/\/ start from end of table\n        i = m,\n        j = n\n    while (i > 0 || j > 0) {\n        \/\/ \"keep\" if i and j words at current position match\n        if (i > 0 && j > 0 && origWords[i - 1] === editedWords[j - 1]) {\n            \/\/ prepend <span> for kept word\n            ops.unshift({ type: \"keep\", word: editedWords[j - 1] })\n            i--\n            j--\n            \/\/ \"add\" if no match and j word has no i counterpart (move left)\n            \/\/ prefer add over remove if tie in LCS length (arbitrary choice)\n        } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {\n            ops.unshift({ type: \"add\", word: editedWords[j - 1] })\n            j--\n        } else {\n            \/\/ \"remove\" if no match and i word has no j counterpart (move up)\n            ops.unshift({ type: \"remove\", word: origWords[i - 1] })\n            i--\n        }\n    }\n\n    \/\/ apply stored edit operations to build final diff display\n    ops.forEach(function (op, k) {\n        \/\/ create a <span> for each word (word-level operation) and style according to operation type\n        var span = document.createElement(\"span\")\n        \/\/ test if word is punctuation\n        var isPunct = \/^[^a-zA-Z0-9']$\/.test(op.word)\n        \/\/ remove whitespace from start\/end of punctuation tokens to avoid weird spacing in the diff display but keep spacing for regular words\n        span.textContent = (k > 0 && !isPunct ? \" \" : \"\") + op.word\n        \/\/ style <span> according to operation type\n        if (op.type === \"add\") {\n            span.className = \"diff-add\"\n        } else if (op.type === \"remove\") {\n            span.className = \"diff-remove\"\n        }\n        result.appendChild(span)\n    })\n\n    return result\n}\n\n\/\/ --- answer validation ---\nfunction isValidExplanation(text) {\n    var trimmed = text.trim()\n\n    \/\/ min 8 characters\n    if (trimmed.length < 8) return false\n\n    \/\/ min 2 words\n    var words = trimmed.split(\/\\s+\/).filter(function (w) {\n        return w.length > 0\n    })\n    if (words.length < 2) return false\n\n    \/\/ min 2 distinct words\n    var lower = words.map(function (w) {\n        return w.toLowerCase()\n    })\n    var unique = lower.filter(function (w, i) {\n        return lower.indexOf(w) === i\n    })\n    if (unique.length < 2) return false\n\n    \/\/ min 1 vowel\n    if (!\/[aeiouAEIOU]\/.test(trimmed)) return false\n\n    \/\/ less than half of all characters are digits\n    var digitCount = (trimmed.match(\/[0-9]\/g) || []).length\n    if (digitCount > trimmed.length \/ 2) return false\n\n    return true\n}\n\nfunction saveExplanations() {\n    var explanations = []\n    document.querySelectorAll(\".explanationBox\").forEach(function (box) {\n        explanations.push({\n            index: parseInt(box.dataset.index, 10),\n            explanation: box.value.trim(),\n        })\n    })\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditExplanationsJSON\",\n        \/\/ JSON.stringify(explanations),\n        btoa(unescape(encodeURIComponent(JSON.stringify(explanations)))),\n    )\n}\n\n\/\/ ----------\n\/\/ GLOBAL VARS\n\/\/ ----------\nvar qContainer\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    \/\/ get question container\n    qContainer = this.getQuestionContainer()\n\n    \/\/ get raw sentence pairs from embedded data\n    var rawSentencePairs = \"${e:\/\/Field\/EditPairsJSON}\"\n\n    \/\/ decode and parse pairs from JSON\n    var pairs\n    var json = decodeURIComponent(escape(atob(rawSentencePairs)))\n    pairs = JSON.parse(json)\n\n    \/\/ --- display ---\n    \/\/ hide default Qualtrics text box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    \/\/ create main container as div\n    var container = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(container)\n\n    \/\/ render one block per sentence pair\n    pairs.forEach(function (pair, idx) {\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        \/\/ header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        \/\/ original sentence\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n        var origStrong = document.createElement(\"div\")\n        origStrong.className =\n            \"sentence_type-label sentence_type-label--original\"\n        origStrong.textContent = \"Original\"\n        origDiv.appendChild(origStrong)\n        origDiv.appendChild(document.createTextNode(pair.orig))\n        wrapper.appendChild(origDiv)\n\n        \/\/ submitted sentence\n        var editedDiv = document.createElement(\"div\")\n        \/\/ check edits were made => to determine display style + whether to attach explanation box\n        var isModified = pair.orig !== pair.edited\n        editedDiv.className =\n            \"sentence_block-edit\" +\n            (isModified ? \" sentence_block-edit--modified\" : \"\")\n        var editedStrong = document.createElement(\"div\")\n        editedStrong.className =\n            \"sentence_type-label \" +\n            (isModified\n                ? \"sentence_type-label--edit\"\n                : \"sentence_type-label--original\")\n        \/\/ label\n        editedStrong.textContent = isModified ? \"Your edit\" : \"Unchanged\"\n        editedDiv.appendChild(editedStrong)\n        editedDiv.appendChild(wordDiff(pair.orig, pair.edited))\n        wrapper.appendChild(editedDiv)\n\n        \/\/ explanation prompt + text box only if modified\n        if (isModified) {\n            var label = document.createElement(\"div\")\n            label.className = \"explanation-label\"\n            label.textContent = \"Why did you make this\/these change(s)?\"\n            wrapper.appendChild(label)\n\n            var explanationBox = document.createElement(\"textarea\")\n            explanationBox.rows = 3\n            explanationBox.className = \"explanation-textarea explanationBox\"\n            explanationBox.dataset.index = idx\n            wrapper.appendChild(explanationBox)\n        }\n\n        container.appendChild(wrapper)\n    })\n\n    \/\/ --- require all & valid explanations ---\n    var nextBtn = document.getElementById(\"NextButton\")\n\n    if (nextBtn) {\n        \/\/ next-click listener\n        nextBtn.addEventListener(\n            \"click\",\n            function (e) {\n                var boxes = document.querySelectorAll(\".explanationBox\")\n                var allFilled = true\n                var firstInvalidBox = null \/\/ keep track of the first invalid box to jump back to if needed\n\n                boxes.forEach(function (box) {\n                    box.style.border = \"1px solid #ddd\"\n                    var errorMsg =\n                        box.parentNode.querySelector(\".explanationError\")\n                    if (errorMsg) errorMsg.remove()\n\n                    \/\/ check validity of explanation text\n                    if (!isValidExplanation(box.value)) {\n                        allFilled = false\n                        box.style.border = \"1px solid #e57373\"\n                        var error = document.createElement(\"div\")\n                        error.className = \"explanationError explanation-error\"\n                        error.textContent =\n                            \"Please explain why you made this change.\"\n                        box.parentNode.insertBefore(error, box.nextSibling)\n                        if (!firstInvalidBox) firstInvalidBox = box\n                    }\n                })\n\n                \/\/ if invalid or incomplete answers, scroll to first problematic box\n                if (!allFilled) {\n                    e.stopImmediatePropagation()\n                    e.preventDefault()\n                    firstInvalidBox.scrollIntoView({\n                        behavior: \"smooth\",\n                        block: \"center\",\n                    })\n                    firstInvalidBox.focus()\n                } else {\n                    \/\/ if all validly filled, save explanations\n                    saveExplanations()\n                }\n            },\n            true,\n        )\n    } else {\n        console.log(\"NextButton not found\")\n    }\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    \/\/ fallback save in case addOnPageSubmit fires without going through the click handler\n    \/\/ note: then explanations are not validated\n    saveExplanations()\n})","QuestionText_Unsafe":"Below you can find each original sentence alongside your edited version. <b>Explain<\/b> each change you made in the box below each pair."}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID54","SecondaryAttribute":"Imagine you find yourself in the following situation. As part of a group project, your team has t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Imagine you find yourself in the following situation.<br \/><br \/>\n\nAs part of a group project, your team has to submit a 200-word news article and\nyour teammate, Brandon, is in charge of writing it. To do so, he used the newest\nLLM, designed to have a very human-like writing style.\n<br \/><br \/>\n\nHowever, this puts your group at risk. Your professor actively tracks new\ndevelopments in LLMs and has already cautioned against their use in coursework.\nYou are worried he will suspect the article was produced with the help of an\nLLM, which would penalize the entire group.\n<br \/><br \/>\n\n<strong>Your task<\/strong> is therefore to edit the text so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br \/><br \/>\n\nTo get a better sense of the writing style of this new LLM, you first generate\ntwo sample articles using it. They are shown below.<br \/><br \/>\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Example 1<\/div>\n        <div class=\"stimulus-title\">__PRIME_1_TITLE__<\/div>\n        <div class=\"stimulus-body\">__PRIME_1_PARAGRAPHS_HTML__<\/div>\n    <\/div>\n\n    <div class=\"card\">\n        <div class=\"card-label\">Example 2<\/div>\n        <div class=\"stimulus-title\">__PRIME_2_TITLE__<\/div>\n        <div class=\"stimulus-body\">__PRIME_2_PARAGRAPHS_HTML__<\/div>\n    <\/div>\n<\/div>\n\n<br \/>\nWith these examples in mind, you now turn to\n<strong>Brandon's text<\/strong> below. It will be shown again on the next page\nwith space to make your edits. <br \/><br \/>\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Brandon's essay<\/div>\n        <div class=\"stimulus-title\">__STIMULUS_TITLE__<\/div>\n        <div class=\"stimulus-body\">__STIMULUS_PARAGRAPHS_HTML__<\/div>\n    <\/div>\n<\/div>\n","DefaultChoices":false,"DataExportTag":"instruct_c0","QuestionID":"QID54","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Imagine you find yourself in the following situation. As part of a group project, your team has t...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Imagine you find yourself in the following situation.<br \/><br \/>\n\nAs part of a group project, your team is required to submit a 200-word essay.\nYour teammate, Brandon, is responsible for writing this essay. He sent you his\ndraft, but also admitted that he used an LLM to generate it. He tried assuring\nyou that the LLM he used is a new one, designed to have a very human-like\nwriting style. <br \/><br \/>\n\nHowever, this puts your group at risk. Your professor has expressed concerns\nabout students using LLMs to complete assignments. You don't want to make your\nprofessor suspicious and you are worried that Brandon's essay could be\nidentified as AI-generated, which would negatively affect the entire group.\n<br \/><br \/>\n\n<strong>Your task<\/strong> is to edit Brandon's essay so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br \/><br \/>\n\nTo get a better sense of the writing style of this LLM, you first generate three\nsample essays using it. They are shown below.<br \/><br \/>\n\n<div>\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_1_LABEL__<\/div>\n\t\t<div class=\"stimulus-title\">__PRIME_1_TOPIC__<\/div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t__PRIME_1_PARAGRAPHS_HTML__\n\t\t<\/div>\n\t<\/div>\n\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_2_LABEL__<\/div>\n\t\t<div class=\"stimulus-title\">__PRIME_2_TOPIC__<\/div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t__PRIME_2_PARAGRAPHS_HTML__\n\t\t<\/div>\n\t<\/div>\n\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_3_LABEL__<\/div>\n\t\t<div class=\"stimulus-title\">__PRIME_3_TOPIC__<\/div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t__PRIME_3_PARAGRAPHS_HTML__\n\t\t<\/div>\n\t<\/div>\n<\/div>\n\t\n<br \/>\nWith these samples in mind, you now turn to <strong>Brandon's essay<\/strong>:\n<br \/><br \/>\n\n<div>\n\t<div class=\"stimulus-card\">\n\t<div class=\"stimulus-label\">Brandon's essay<\/div>\n\t<div class=\"stimulus-title\">__STIMULUS_TOPIC__<\/div>\n\t<div class=\"stimulus-body\">\n        __STIMULUS_PARAGRAPHS_HTML__\n\t\t<\/div>\n\t<\/div>\n<\/div>\n","QuestionJS":false}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID64","SecondaryAttribute":"What is your Prolific ID?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your Prolific ID?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var completedIDs = [];\n    var pid = \"${e:\/\/Field\/PROLIFIC_PID}\";\n\n    if (completedIDs.indexOf(pid) !== -1) {\n        Qualtrics.SurveyEngine.setEmbeddedData(\"IsDuplicate\", \"true\");\n    }\n});\n\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":{"TEXT":{"Text":"${e:\/\/Field\/PROLIFIC_PID}"}},"DataExportTag":"pid","QuestionID":"QID64","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your Prolific ID?","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span><span> False<\/span>","LogicType":"BooleanValue","Type":"Expression","Value":"False"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"What is your age in years?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your age in years?","DefaultChoices":false,"DataExportTag":"age","QuestionID":"QID8","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your age in years?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"","Max":"","NumDecimals":""}}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"In a typical month, how often do you use an LLM chatbot (e.g., ChatGPT, Copilot, Gemini, Claude)...","TertiaryAttribute":null,"Payload":{"QuestionText":"In a typical month, how often do you use an LLM chatbot (e.g., ChatGPT, Copilot, Gemini, Claude) for any purpose?","DefaultChoices":false,"DataExportTag":"LLM_use","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In a typical month, how often do you use an LLM chatbot (e.g., ChatGPT, Copilot, Gemini, Claude)...","Choices":{"1":{"Display":"Every day or almost every day"},"2":{"Display":"Several times per week"},"3":{"Display":"About once a week"},"4":{"Display":"2-3 times in the past month"},"5":{"Display":"Once in the past month"},"6":{"Display":"I have not used any AI chatbot \/ LLM in the past 30 days"},"7":{"Display":"I have never used an AI chatbot \/ LLM"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID9","QuestionText_Unsafe":"In a typical month, how often do you use an LLM chatbot (e.g., ChatGPT, Copilot, Gemini, Claude) for any purpose?"}},{"SurveyID":"SV_cwM3MQomjAv0nJA","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}