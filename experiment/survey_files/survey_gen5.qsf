                "Selector": "ML",
                "DataVisibility": {
                    "Private": false,
                    "Hidden": false
                },
                "Configuration": {
                    "QuestionDescriptionOption": "UseText"
                },
                "QuestionDescription": "Brandon's text is shown again sentence by sentence, each followed by an editable text box prefill...",
                "Validation": {
                    "Settings": {
