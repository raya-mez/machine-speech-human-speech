                "QuestionJS": "var qContainer\nvar originalSentences\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    qContainer = this.getQuestionContainer()\n\n    var title = \"Weird and wonderful Christmas traditions across Europe\"\n    originalSentences = [\"From churchgoers in Venezuela who roller skate, to children in Germany who throw shoes.\", \"Every December Europe is nice place with traditions that sound little strange for Americans but, nonetheless are cherished by various countries in Europe.\", \"In Catalonia, Spain the Caga Ti\\u00f3 is a log that is placed in the house and fed for weeks before Christmas.\", \"On Christmas Eve, children beat the log with sticks while singing, and waiting and hoping for it to produce for the eager children sweets and small gifts.\", \"The festive season in Austria and parts of southern Germany is not celebrated in the same way as other countries, it is dark and eerie, not as warm or bright and just a little creepy.\", \"Men dressed as horned Krampus creatures walk through town squares, rattling chains and playfully chasing children and other fun-loving spectators, reviving a centuries old Alpine legend meant to frighten naughty children.\", \"In Ukraine, Christmas tree is illuminated with fake spider webs, inspired by a legend in which spiders spun silver threads to help a poor family celebrate their Christmases.\", \"Households in Norway tend to hide their brooms on Christmas Eve to prevent mischievous and naughty spirits said to fly in the sky during the night.\", \"These bizarre traditions showcase Europe\\u2019s rich history of folklore, faith and fun, reminding visitors that the magic of Christmas often lies in the delightfully unexpected places.\", \"From Italy\\u2019s gift bearing witch La Befana to the Czech custom of tossing shoes to predict marriage, the continent embraces the joys of Christmas celebrations in this festive winter season.\"]\n\n    // hide default text input box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    // create div element for new container to be filled with sentence editing blocks\n    var textEntryContainer = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(textEntryContainer)\n\n    // create container title element\n    var titleWrapper = document.createElement(\"div\")\n    titleWrapper.className = \"card\"\n    titleWrapper.style.backgroundColor = \"#fafafa\" // slightly different to distinguish from sentences\n\n    var titleLabel = document.createElement(\"div\")\n    titleLabel.className = \"card-label\"\n    titleLabel.textContent = \"Title\"\n    titleWrapper.appendChild(titleLabel)\n\n    var titleEl = document.createElement(\"div\")\n    titleEl.className = \"stimulus-title\"\n    titleEl.textContent = title\n    titleWrapper.appendChild(titleEl)\n\n    textEntryContainer.appendChild(titleWrapper)\n\n    // create individual sentence elements\n    originalSentences.forEach(function (sentence, idx) {\n        // wrapper (the full card)\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        // card header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        // original sentence display\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n\n        // create a separate container for the actual text to apply styles\n        var origText = document.createElement(\"div\")\n        origText.textContent = sentence\n\n        // original sentence label\n        var origLabel = document.createElement(\"div\")\n        origLabel.className =\n            \"sentence_type-label sentence_type-label--orig\"\n        origLabel.textContent = \"Original\"\n\n        origDiv.appendChild(origLabel)\n        origDiv.appendChild(origText) // append text as a div to ensure styling\n        wrapper.appendChild(origDiv)\n\n        // edit label\n        var editLabel = document.createElement(\"div\")\n        editLabel.className = \"sentence_type-label sentence_type-label--edit\"\n        editLabel.textContent = \"Your edit\"\n        wrapper.appendChild(editLabel)\n\n        // text area for user edit\n        var textarea = document.createElement(\"textarea\")\n        textarea.value = sentence // prefilled with original sentence\n        textarea.className = \"sentenceBox edit-textarea\"\n        textarea.dataset.index = idx\n        wrapper.appendChild(textarea)\n\n        textEntryContainer.appendChild(wrapper)\n\n        // adjust height to fit the prefilled content\n        textarea.style.height = \"auto\"\n        textarea.style.height = textarea.scrollHeight + \"px\"\n    })\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    // save original:edited sentence pairs\n    var resultPairs = []\n\n    qContainer.querySelectorAll(\".sentenceBox\").forEach(function (box) {\n        // trim both to avoid whitespace issues (user asked to explain a white space removal they didn't make)\n        var orig = originalSentences[parseInt(box.dataset.index, 10)].trim()\n        var edited = box.value.trim()\n        resultPairs.push({ orig: orig, edited: edited })\n    })\n\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditPairsJSON\", \n        // JSON.stringify(resultPairs)\n        btoa(unescape(encodeURIComponent(JSON.stringify(resultPairs)))), // base64 encoding (safer storage)\n    )\n})",
                "QuestionText_Unsafe": "You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated.\n<br><br>\nThe essay is displayed below sentence by sentence, each followed by an editable text box, which is prefilled with that sentence. Edit as many sentences as you like using the following rules:\n<ul> \n\t<li>To <b>revise wording</b>, edit the sentence directly in its box.</li>\n\t<li>To <b>merge sentences</b>, write the full merged sentence in the text box of the first sentence's box; leave the following merged sentence box(es) empty.</li> \n\t<li>To <b>split a sentence</b>, write all resulting sentences in the box of the original sentence.</li> \n\t<li>To <b>delete a sentence</b>, leave its box empty.</li>\n</ul>\nMake all changes you find appropriate before proceeding with the survey.<br><br>"
            }
        },
