                "QuestionJS": "var qContainer\nvar originalSentences\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    qContainer = this.getQuestionContainer()\n\n    var title = \"Former First Lady Barbara Bush has died at 92\"\n    originalSentences = [\"Barbara Bush, the former first lady of the United States and matriarch of one of the country\\u2019s most prominent political families, has died at the age of 92.\", \"A family spokesperson confirmed that Bush passed away peacefully at her home in Houston, surrounded by loved ones.\", \"Wife of the 41st president, George H.W.\", \"Bush, she served as first lady from 1989 to 1993.\", \"Known for her trademark white hair, sharp wit and outspoken advocacy for literacy, Bush championed education initiatives throughout her public life.\", \"She founded the Barbara Bush Foundation for Family Literacy in 1989, helping raise millions of dollars to promote reading and writing programs nationwide.\", \"Born Barbara Pierce in New York City in 1925, she married George H.W.\", \"Bush in 1945 and raised six children, including former President George W. Bush and former Florida Governor Jeb Bush.\", \"She was widely regarded as a steadying force within the Bush family and a candid voice in American politics.\", \"Tributes poured in from leaders across the political spectrum, praising her dedication to public service, family and country.\", \"Funeral arrangements are expected to be announced in the coming days.\", \"She will be remembered for her resilience and enduring grace throughout her life.\"]\n\n    // hide default text input box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    // create div element for new container to be filled with sentence editing blocks\n    var textEntryContainer = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(textEntryContainer)\n\n    // create container title element\n    var titleWrapper = document.createElement(\"div\")\n    titleWrapper.className = \"card\"\n    titleWrapper.style.backgroundColor = \"#fafafa\" // slightly different to distinguish from sentences\n\n    var titleLabel = document.createElement(\"div\")\n    titleLabel.className = \"card-label\"\n    titleLabel.textContent = \"Title\"\n    titleWrapper.appendChild(titleLabel)\n\n    var titleEl = document.createElement(\"div\")\n    titleEl.className = \"stimulus-title\"\n    titleEl.textContent = title\n    titleWrapper.appendChild(titleEl)\n\n    textEntryContainer.appendChild(titleWrapper)\n\n    // create individual sentence elements\n    originalSentences.forEach(function (sentence, idx) {\n        // wrapper (the full card)\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        // card header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        // original sentence display\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n\n        // create a separate container for the actual text to apply styles\n        var origText = document.createElement(\"div\")\n        origText.textContent = sentence\n\n        // original sentence label\n        var origLabel = document.createElement(\"div\")\n        origLabel.className =\n            \"sentence_type-label sentence_type-label--orig\"\n        origLabel.textContent = \"Original\"\n\n        origDiv.appendChild(origLabel)\n        origDiv.appendChild(origText) // append text as a div to ensure styling\n        wrapper.appendChild(origDiv)\n\n        // edit label\n        var editLabel = document.createElement(\"div\")\n        editLabel.className = \"sentence_type-label sentence_type-label--edit\"\n        editLabel.textContent = \"Your edit\"\n        wrapper.appendChild(editLabel)\n\n        // text area for user edit\n        var textarea = document.createElement(\"textarea\")\n        textarea.value = sentence // prefilled with original sentence\n        textarea.className = \"sentenceBox edit-textarea\"\n        textarea.dataset.index = idx\n        wrapper.appendChild(textarea)\n\n        textEntryContainer.appendChild(wrapper)\n\n        // adjust height to fit the prefilled content\n        textarea.style.height = \"auto\"\n        textarea.style.height = textarea.scrollHeight + \"px\"\n    })\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    // save original:edited sentence pairs\n    var resultPairs = []\n\n    qContainer.querySelectorAll(\".sentenceBox\").forEach(function (box) {\n        // trim both to avoid whitespace issues (user asked to explain a white space removal they didn't make)\n        var orig = originalSentences[parseInt(box.dataset.index, 10)].trim()\n        var edited = box.value.trim()\n        resultPairs.push({ orig: orig, edited: edited })\n    })\n\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditPairsJSON\", \n        // JSON.stringify(resultPairs)\n        btoa(unescape(encodeURIComponent(JSON.stringify(resultPairs)))), // base64 encoding (safer storage)\n    )\n})",
                "QuestionText_Unsafe": "You will now edit Brandon's essay so that it reads convincingly as human-written and is unlikely to be identified as LLM-generated.\n<br><br>\nThe essay is displayed below sentence by sentence, each followed by an editable text box, which is prefilled with that sentence. Edit as many sentences as you like using the following rules:\n<ul> \n\t<li>To <b>revise wording</b>, edit the sentence directly in its box.</li>\n\t<li>To <b>merge sentences</b>, write the full merged sentence in the text box of the first sentence's box; leave the following merged sentence box(es) empty.</li> \n\t<li>To <b>split a sentence</b>, write all resulting sentences in the box of the original sentence.</li> \n\t<li>To <b>delete a sentence</b>, leave its box empty.</li>\n</ul>\nMake all changes you find appropriate before proceeding with the survey.<br><br>"
            }
        },
        {
            "SurveyID": "SV_cwM3MQomjAv0nJA",
            "Element": "SQ",
            "PrimaryAttribute": "QID1219691489",
            "SecondaryAttribute": "Below you can find each original sentence alongside your edited version. Explain each change you...",
            "TertiaryAttribute": null,
            "Payload": {
                "QuestionText": "Below you can find each original sentence alongside your edited version. \n<b>Explain</b> each change you made in the box below each pair.",
                "DefaultChoices": false,
                "DataExportTag": "explain_c12",
                "QuestionID": "QID1219691489",
                "QuestionType": "TE",
                "Selector": "ML",
                "DataVisibility": {
                    "Private": false,
                    "Hidden": false
                },
                "Configuration": {
                    "QuestionDescriptionOption": "UseText"
                },
                "QuestionDescription": "Below you can find each original sentence alongside your edited version. Explain each change you...",
                "Validation": {
                    "Settings": {
                        "ForceResponse": "OFF",
                        "ForceResponseType": "ON",
                        "Type": "None",
                        "MinChars": "1"
                    }
                },
                "GradingData": [],
                "Language": [],
                "NextChoiceId": 4,
                "NextAnswerId": 1,
                "SearchSource": {
                    "AllowFreeResponse": "false"
                },
                "QuestionJS": "// ----------\n// HELPER FUNCS\n// ----------\n\n// --- word-level diffs helper ---\nfunction wordDiff(orig, edited) {\n    // tokenize: split into words; punctuation treated as separate tokens\n    function tokenize(str) {\n        return str.match(/[a-zA-Z0-9']+|[^a-zA-Z0-9'\\s]/g) || []\n    }\n\n    var origWords = tokenize(orig)\n    var editedWords = tokenize(edited)\n    var result = document.createDocumentFragment() // build diffs display in a fragment to be inserted into the DOM at once\n    // fragment is iteratively built from <span> elements\n\n    var m = origWords.length,\n        n = editedWords.length\n    var dp = [] // dynamic programming table\n\n    // initialize dp table\n    for (var i = 0; i <= m; i++) {\n        dp[i] = []\n        for (var j = 0; j <= n; j++) dp[i][j] = 0\n    }\n\n    // compute longest common subsequence length\n    // iterate over original (i) and edited (j) sentences, word by word\n    for (var i = 1; i <= m; i++)\n        for (var j = 1; j <= n; j++)\n            // fill dp table\n            dp[i][j] =\n                // note: dp[1][1] corresp to origWords[0] vs editedWords[0] => hence -1 offset\n                origWords[i - 1] === editedWords[j - 1] // test match\n                    ? dp[i - 1][j - 1] + 1 // if match => extend LCS count by 1\n                    : Math.max(dp[i - 1][j], dp[i][j - 1]) // if no match => take max achievable LCS by removing from orig or edited\n\n    // backtrack to find and store edit operations (keep/add/remove)\n    var ops = [],\n        // start from end of table\n        i = m,\n        j = n\n    while (i > 0 || j > 0) {\n        // \"keep\" if i and j words at current position match\n        if (i > 0 && j > 0 && origWords[i - 1] === editedWords[j - 1]) {\n            // prepend <span> for kept word\n            ops.unshift({ type: \"keep\", word: editedWords[j - 1] })\n            i--\n            j--\n            // \"add\" if no match and j word has no i counterpart (move left)\n            // prefer add over remove if tie in LCS length (arbitrary choice)\n        } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {\n            ops.unshift({ type: \"add\", word: editedWords[j - 1] })\n            j--\n        } else {\n            // \"remove\" if no match and i word has no j counterpart (move up)\n            ops.unshift({ type: \"remove\", word: origWords[i - 1] })\n            i--\n        }\n    }\n\n    // apply stored edit operations to build final diff display\n    ops.forEach(function (op, k) {\n        // create a <span> for each word (word-level operation) and style according to operation type\n        var span = document.createElement(\"span\")\n        // test if word is punctuation\n        var isPunct = /^[^a-zA-Z0-9']$/.test(op.word)\n        // remove whitespace from start/end of punctuation tokens to avoid weird spacing in the diff display but keep spacing for regular words\n        span.textContent = (k > 0 && !isPunct ? \" \" : \"\") + op.word\n        // style <span> according to operation type\n        if (op.type === \"add\") {\n            span.className = \"diff-add\"\n        } else if (op.type === \"remove\") {\n            span.className = \"diff-remove\"\n        }\n        result.appendChild(span)\n    })\n\n    return result\n}\n\n// --- answer validation ---\nfunction isValidExplanation(text) {\n    var trimmed = text.trim()\n\n    // min 8 characters\n    if (trimmed.length < 8) return false\n\n    // min 2 words\n    var words = trimmed.split(/\\s+/).filter(function (w) {\n        return w.length > 0\n    })\n    if (words.length < 2) return false\n\n    // min 2 distinct words\n    var lower = words.map(function (w) {\n        return w.toLowerCase()\n    })\n    var unique = lower.filter(function (w, i) {\n        return lower.indexOf(w) === i\n    })\n    if (unique.length < 2) return false\n\n    // min 1 vowel\n    if (!/[aeiouAEIOU]/.test(trimmed)) return false\n\n    // less than half of all characters are digits\n    var digitCount = (trimmed.match(/[0-9]/g) || []).length\n    if (digitCount > trimmed.length / 2) return false\n\n    return true\n}\n\nfunction saveExplanations() {\n    var explanations = []\n    document.querySelectorAll(\".explanationBox\").forEach(function (box) {\n        explanations.push({\n            index: parseInt(box.dataset.index, 10),\n            explanation: box.value.trim(),\n        })\n    })\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        \"EditExplanationsJSON\",\n        // JSON.stringify(explanations),\n        btoa(unescape(encodeURIComponent(JSON.stringify(explanations)))),\n    )\n}\n\n// ----------\n// GLOBAL VARS\n// ----------\nvar qContainer\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    // get question container\n    qContainer = this.getQuestionContainer()\n\n    // get raw sentence pairs from embedded data\n    var rawSentencePairs = \"${e://Field/EditPairsJSON}\"\n\n    // decode and parse pairs from JSON\n    var pairs\n    var json = decodeURIComponent(escape(atob(rawSentencePairs)))\n    pairs = JSON.parse(json)\n\n    // --- display ---\n    // hide default Qualtrics text box\n    var defaultInput = qContainer.querySelector(\"textarea\")\n    defaultInput.style.display = \"none\"\n\n    // create main container as div\n    var container = document.createElement(\"div\")\n    defaultInput.parentNode.appendChild(container)\n\n    // render one block per sentence pair\n    pairs.forEach(function (pair, idx) {\n        var wrapper = document.createElement(\"div\")\n        wrapper.className = \"card\"\n\n        // header\n        var header = document.createElement(\"div\")\n        header.className = \"card-label\"\n        header.textContent = \"Sentence \" + (idx + 1)\n        wrapper.appendChild(header)\n\n        // original sentence\n        var origDiv = document.createElement(\"div\")\n        origDiv.className = \"sentence_block-orig\"\n        var origStrong = document.createElement(\"div\")\n        origStrong.className =\n            \"sentence_type-label sentence_type-label--original\"\n        origStrong.textContent = \"Original\"\n        origDiv.appendChild(origStrong)\n        origDiv.appendChild(document.createTextNode(pair.orig))\n        wrapper.appendChild(origDiv)\n\n        // submitted sentence\n        var editedDiv = document.createElement(\"div\")\n        // check edits were made => to determine display style + whether to attach explanation box\n        var isModified = pair.orig !== pair.edited\n        editedDiv.className =\n            \"sentence_block-edit\" +\n            (isModified ? \" sentence_block-edit--modified\" : \"\")\n        var editedStrong = document.createElement(\"div\")\n        editedStrong.className =\n            \"sentence_type-label \" +\n            (isModified\n                ? \"sentence_type-label--edit\"\n                : \"sentence_type-label--original\")\n        // label\n        editedStrong.textContent = isModified ? \"Your edit\" : \"Unchanged\"\n        editedDiv.appendChild(editedStrong)\n        editedDiv.appendChild(wordDiff(pair.orig, pair.edited))\n        wrapper.appendChild(editedDiv)\n\n        // explanation prompt + text box only if modified\n        if (isModified) {\n            var label = document.createElement(\"div\")\n            label.className = \"explanation-label\"\n            label.textContent = \"Why did you make this/these change(s)?\"\n            wrapper.appendChild(label)\n\n            var explanationBox = document.createElement(\"textarea\")\n            explanationBox.rows = 3\n            explanationBox.className = \"explanation-textarea explanationBox\"\n            explanationBox.dataset.index = idx\n            wrapper.appendChild(explanationBox)\n        }\n\n        container.appendChild(wrapper)\n    })\n\n    // --- require all & valid explanations ---\n    var nextBtn = document.getElementById(\"NextButton\")\n\n    if (nextBtn) {\n        // next-click listener\n        nextBtn.addEventListener(\n            \"click\",\n            function (e) {\n                var boxes = document.querySelectorAll(\".explanationBox\")\n                var allFilled = true\n                var firstInvalidBox = null // keep track of the first invalid box to jump back to if needed\n\n                boxes.forEach(function (box) {\n                    box.style.border = \"1px solid #ddd\"\n                    var errorMsg =\n                        box.parentNode.querySelector(\".explanationError\")\n                    if (errorMsg) errorMsg.remove()\n\n                    // check validity of explanation text\n                    if (!isValidExplanation(box.value)) {\n                        allFilled = false\n                        box.style.border = \"1px solid #e57373\"\n                        var error = document.createElement(\"div\")\n                        error.className = \"explanationError explanation-error\"\n                        error.textContent =\n                            \"Please explain why you made this change.\"\n                        box.parentNode.insertBefore(error, box.nextSibling)\n                        if (!firstInvalidBox) firstInvalidBox = box\n                    }\n                })\n\n                // if invalid or incomplete answers, scroll to first problematic box\n                if (!allFilled) {\n                    e.stopImmediatePropagation()\n                    e.preventDefault()\n                    firstInvalidBox.scrollIntoView({\n                        behavior: \"smooth\",\n                        block: \"center\",\n                    })\n                    firstInvalidBox.focus()\n                } else {\n                    // if all validly filled, save explanations\n                    saveExplanations()\n                }\n            },\n            true,\n        )\n    } else {\n        console.log(\"NextButton not found\")\n    }\n})\n\nQualtrics.SurveyEngine.addOnPageSubmit(function () {\n    // fallback save in case addOnPageSubmit fires without going through the click handler\n    // note: then explanations are not validated\n    saveExplanations()\n})",
                "QuestionText_Unsafe": "Below you can find each original sentence alongside your edited version. <b>Explain</b> each change you made in the box below each pair."
            }
        },
        {
            "SurveyID": "SV_cwM3MQomjAv0nJA",
            "Element": "SQ",
            "PrimaryAttribute": "QID1219691490",
            "SecondaryAttribute": "Imagine you find yourself in the following situation. As part of a group project, your team has t...",
            "TertiaryAttribute": null,
            "Payload": {
                "QuestionText": "Imagine you find yourself in the following situation.<br /><br />\n\nAs part of a group project, your team has to submit a 200-word news article and\nyour teammate, Brandon, is in charge of writing it. To do so, he used the newest\nLLM, designed to have a very human-like writing style.\n<br /><br />\n\nHowever, this puts your group at risk. Your professor actively tracks new\ndevelopments in LLMs and has already cautioned against their use in coursework.\nYou are worried he will suspect the article was produced with the help of an\nLLM, which would penalize the entire group.\n<br /><br />\n\n<strong>Your task</strong> is therefore to edit the text so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br /><br />\n\nTo get a better sense of the writing style of this new LLM, you first generate\ntwo sample articles using it. They are shown below.<br /><br />\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Example 1</div>\n        <div class=\"stimulus-title\">Former First Lady Barbara Bush has died at 92</div>\n        <div class=\"stimulus-body\">   <p>Barbara Bush, the former first lady of the United States and matriarch of one of the country\u2019s most prominent political families, has died at the age of 92. A family spokesperson confirmed that Bush passed away peacefully at her home in Houston, surrounded by loved ones.</p>\n           <p>Wife of the 41st president, George H.W. Bush, she served as first lady from 1989 to 1993. Known for her trademark white hair, sharp wit and outspoken advocacy for literacy, Bush championed education initiatives throughout her public life. She founded the Barbara Bush Foundation for Family Literacy in 1989, helping raise millions of dollars to promote reading and writing programs nationwide.</p>\n           <p>Born Barbara Pierce in New York City in 1925, she married George H.W. Bush in 1945 and raised six children, including former President George W. Bush and former Florida Governor Jeb Bush. She was widely regarded as a steadying force within the Bush family and a candid voice in American politics.</p>\n           <p>Tributes poured in from leaders across the political spectrum, praising her dedication to public service, family and country. Funeral arrangements are expected to be announced in the coming days. She will be remembered for her resilience and enduring grace throughout her life.</p></div>\n    </div>\n\n    <div class=\"card\">\n        <div class=\"card-label\">Example 2</div>\n        <div class=\"stimulus-title\">Newly Discovered Prehistoric Worm Creature 'Strange Beyond Measure'</div>\n        <div class=\"stimulus-body\">   <p>Scientists have unveiled a newly discovered prehistoric worm-like creature they describe as \u201cstrange beyond measure,\u201d shedding light on an unusual branch of early animal evolution. The fossilized remains, found in 520\u2011million\u2011year\u2011old marine sediments in western China, reveal a soft-bodied organism with a tubular form, ringed segments, and a circular mouth lined with sharp, backward-facing spines.</p>\n           <p>Measuring just a few inches long, the creature likely lived on the seafloor during the Cambrian Period, a time when complex life rapidly diversified. Researchers believe it used its spiny mouth to latch onto prey or organic debris, drawing food into a simple digestive tract. Despite its modest size, the worm\u2019s anatomy is unlike that of any modern species.</p>\n           <p>\u201cIt\u2019s strange beyond measure,\u201d said lead paleontologist Dr. Li Wen. \u201cIts combination of features doesn\u2019t neatly fit into any known group, living or extinct.\u201d Advanced imaging techniques revealed preserved muscle fibers and traces of internal organs, offering rare insight into soft-bodied animals that seldom fossilize.</p>\n           <p>The discovery suggests that early marine ecosystems were more diverse and experimental than previously understood. Scientists hope further study will clarify where the enigmatic creature fits on the evolutionary tree and what it reveals about the origins of complex animals.</p></div>\n    </div>\n</div>\n\n<br />\nWith these examples in mind, you now turn to\n<strong>Brandon's text</strong> below. It will be shown again on the next page\nwith space to make your edits. <br /><br />\n\n<div>\n    <div class=\"card\">\n        <div class=\"card-label\">Brandon's essay</div>\n        <div class=\"stimulus-title\">Quantum physicist named Australian of the Year</div>\n        <div class=\"stimulus-body\">   <p>Renowned quantum physicist Dr. Amelia Hart has been named Australian of the Year, honored for her pioneering research in quantum computing and her tireless advocacy for science education. Announced at a ceremony in Canberra on Tuesday night, the award recognizes Hart\u2019s leadership in developing ultra-stable qubits that could dramatically accelerate the arrival of practical quantum technologies.</p>\n           <p>Hart, a professor at the University of Sydney and director of the National Quantum Innovation Centre, has spent two decades advancing methods to reduce error rates in quantum processors. Her team\u2019s breakthrough last year demonstrated a scalable architecture capable of operating at room temperature, a milestone experts say could lower costs and expand commercial applications.</p>\n           <p>Beyond the laboratory, Hart has championed greater access to STEM education for girls and students in regional communities. She has launched mentorship programs, advised government on critical technology policy, and spoken widely about the ethical implications of quantum breakthroughs.</p>\n           <p>Prime Minister said Hart embodies \u201ccuriosity, collaboration and courage.\u201d Accepting the award, Hart dedicated the honor to her students and colleagues, urging sustained investment in research to secure Australia\u2019s place in the global quantum race. She called the moment a reminder of science\u2019s power to unite nations through shared discovery.</p></div>\n    </div>\n</div>\n",
                "DefaultChoices": false,
                "DataExportTag": "instruct_c13",
                "QuestionID": "QID1219691490",
                "QuestionType": "DB",
                "Selector": "TB",
                "DataVisibility": {
                    "Private": false,
                    "Hidden": false
                },
                "Configuration": {
                    "QuestionDescriptionOption": "UseText"
                },
                "QuestionDescription": "Imagine you find yourself in the following situation. As part of a group project, your team has t...",
                "ChoiceOrder": [],
                "Validation": {
                    "Settings": {
                        "Type": "None"
                    }
                },
                "GradingData": [],
                "Language": [],
                "NextChoiceId": 4,
                "NextAnswerId": 1,
                "QuestionText_Unsafe": "Imagine you find yourself in the following situation.<br /><br />\n\nAs part of a group project, your team is required to submit a 200-word essay.\nYour teammate, Brandon, is responsible for writing this essay. He sent you his\ndraft, but also admitted that he used an LLM to generate it. He tried assuring\nyou that the LLM he used is a new one, designed to have a very human-like\nwriting style. <br /><br />\n\nHowever, this puts your group at risk. Your professor has expressed concerns\nabout students using LLMs to complete assignments. You don't want to make your\nprofessor suspicious and you are worried that Brandon's essay could be\nidentified as AI-generated, which would negatively affect the entire group.\n<br /><br />\n\n<strong>Your task</strong> is to edit Brandon's essay so that it reads\nconvincingly as human-written and is unlikely to be identified as LLM-generated.\n<br /><br />\n\nTo get a better sense of the writing style of this LLM, you first generate three\nsample essays using it. They are shown below.<br /><br />\n\n<div>\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_1_LABEL__</div>\n\t\t<div class=\"stimulus-title\">__PRIME_1_TOPIC__</div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t   <p>Barbara Bush, the former first lady of the United States and matriarch of one of the country\u2019s most prominent political families, has died at the age of 92. A family spokesperson confirmed that Bush passed away peacefully at her home in Houston, surrounded by loved ones.</p>\n           <p>Wife of the 41st president, George H.W. Bush, she served as first lady from 1989 to 1993. Known for her trademark white hair, sharp wit and outspoken advocacy for literacy, Bush championed education initiatives throughout her public life. She founded the Barbara Bush Foundation for Family Literacy in 1989, helping raise millions of dollars to promote reading and writing programs nationwide.</p>\n           <p>Born Barbara Pierce in New York City in 1925, she married George H.W. Bush in 1945 and raised six children, including former President George W. Bush and former Florida Governor Jeb Bush. She was widely regarded as a steadying force within the Bush family and a candid voice in American politics.</p>\n           <p>Tributes poured in from leaders across the political spectrum, praising her dedication to public service, family and country. Funeral arrangements are expected to be announced in the coming days. She will be remembered for her resilience and enduring grace throughout her life.</p>\n\t\t</div>\n\t</div>\n\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_2_LABEL__</div>\n\t\t<div class=\"stimulus-title\">__PRIME_2_TOPIC__</div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t   <p>Scientists have unveiled a newly discovered prehistoric worm-like creature they describe as \u201cstrange beyond measure,\u201d shedding light on an unusual branch of early animal evolution. The fossilized remains, found in 520\u2011million\u2011year\u2011old marine sediments in western China, reveal a soft-bodied organism with a tubular form, ringed segments, and a circular mouth lined with sharp, backward-facing spines.</p>\n           <p>Measuring just a few inches long, the creature likely lived on the seafloor during the Cambrian Period, a time when complex life rapidly diversified. Researchers believe it used its spiny mouth to latch onto prey or organic debris, drawing food into a simple digestive tract. Despite its modest size, the worm\u2019s anatomy is unlike that of any modern species.</p>\n           <p>\u201cIt\u2019s strange beyond measure,\u201d said lead paleontologist Dr. Li Wen. \u201cIts combination of features doesn\u2019t neatly fit into any known group, living or extinct.\u201d Advanced imaging techniques revealed preserved muscle fibers and traces of internal organs, offering rare insight into soft-bodied animals that seldom fossilize.</p>\n           <p>The discovery suggests that early marine ecosystems were more diverse and experimental than previously understood. Scientists hope further study will clarify where the enigmatic creature fits on the evolutionary tree and what it reveals about the origins of complex animals.</p>\n\t\t</div>\n\t</div>\n\n\t<div class=\"stimulus-card\">\n\t\t<div class=\"stimulus-label\">__PRIME_3_LABEL__</div>\n\t\t<div class=\"stimulus-title\">__PRIME_3_TOPIC__</div>\n\t\t<div class=\"stimulus-body\">\n\t\t\t__PRIME_3_PARAGRAPHS_HTML__\n\t\t</div>\n\t</div>\n</div>\n\t\n<br />\nWith these samples in mind, you now turn to <strong>Brandon's essay</strong>:\n<br /><br />\n\n<div>\n\t<div class=\"stimulus-card\">\n\t<div class=\"stimulus-label\">Brandon's essay</div>\n\t<div class=\"stimulus-title\">__STIMULUS_TOPIC__</div>\n\t<div class=\"stimulus-body\">\n           <p>Renowned quantum physicist Dr. Amelia Hart has been named Australian of the Year, honored for her pioneering research in quantum computing and her tireless advocacy for science education. Announced at a ceremony in Canberra on Tuesday night, the award recognizes Hart\u2019s leadership in developing ultra-stable qubits that could dramatically accelerate the arrival of practical quantum technologies.</p>\n           <p>Hart, a professor at the University of Sydney and director of the National Quantum Innovation Centre, has spent two decades advancing methods to reduce error rates in quantum processors. Her team\u2019s breakthrough last year demonstrated a scalable architecture capable of operating at room temperature, a milestone experts say could lower costs and expand commercial applications.</p>\n           <p>Beyond the laboratory, Hart has championed greater access to STEM education for girls and students in regional communities. She has launched mentorship programs, advised government on critical technology policy, and spoken widely about the ethical implications of quantum breakthroughs.</p>\n           <p>Prime Minister said Hart embodies \u201ccuriosity, collaboration and courage.\u201d Accepting the award, Hart dedicated the honor to her students and colleagues, urging sustained investment in research to secure Australia\u2019s place in the global quantum race. She called the moment a reminder of science\u2019s power to unite nations through shared discovery.</p>\n\t\t</div>\n\t</div>\n</div>\n",
                "QuestionJS": false
            }
        },
        {
            "SurveyID": "SV_cwM3MQomjAv0nJA",
